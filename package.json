{
    "name": "metal-hub-site",
    "type": "module",
    "version": "0.0.1",
    "scripts": {
        "dev": "astro dev",
        "optimize-images": "node scripts/optimize-images.mjs",
        "build": "node scripts/optimize-images.mjs && astro build",
        "preview": "node scripts/optimize-images.mjs && astro build && wrangler dev",
        "astro": "astro",
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "format": "biome format --write .",
        "check": "astro check && biome check .",
        "prepare": "husky",
        "generate-types": "wrangler types",
        "deploy": "bun run build && rm -rf .wrangler/deploy && wrangler pages deploy dist/client --project-name=metalhub --no-config"
    },
    "lint-staged": {
        "*.{astro,ts,js,json,css}": [
            "biome check --write"
        ]
    },
    "dependencies": {
        "@astrojs/cloudflare": "^14.0.0",
        "@astrojs/sitemap": "^3.7.3",
        "@tailwindcss/vite": "^4.3.1",
        "astro": "^7.0.2",
        "leaflet": "^1.9.4",
        "leaflet-control-geocoder": "^3.3.1",
        "sharp": "^0.35.2",
        "tailwindcss": "^4.3.1"
    },
    "devDependencies": {
        "@astrojs/check": "^0.9.9",
        "@biomejs/biome": "^2.5.1",
        "@types/leaflet": "^1.9.21",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.8",
        "typescript": "^6.0.3",
        "wrangler": "^4.104.0"
    },
    "allowScripts": {
        "husky": true,
        "@biomejs/biome": true
    }
}
