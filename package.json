{
    "name": "metal-hub-site",
    "type": "module",
    "version": "0.0.1",
    "scripts": {
        "dev": "astro dev",
        "build": "astro build",
        "preview": "astro preview",
        "astro": "astro",
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "format": "biome format --write .",
        "check": "astro check && biome check .",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.{astro,ts,js,json,css}": [
            "biome check --write"
        ]
    },
    "dependencies": {
        "@astrojs/check": "^0.9.9",
        "@tailwindcss/vite": "^4.3.1",
        "astro": "^7.0.0",
        "leaflet": "^1.9.4",
        "leaflet-control-geocoder": "^3.3.1",
        "tailwindcss": "^4.3.1",
        "typescript": "^6.0.3"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.5.1",
        "@types/leaflet": "^1.9.21",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.8"
    }
}
