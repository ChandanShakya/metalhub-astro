# Cloudflare Pages caching configuration
# https://developers.cloudflare.com/pages/configuration/headers/

# Static assets (hashed by Astro)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Images
/images/*
  Cache-Control: public, max-age=2592000, stale-while-revalidate=86400

# Fonts
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# HTML pages - short cache with stale-while-revalidate for fast repeat visits
/*.html
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

# Admin - no cache (needs fresh OAuth state)
/admin/*
  Cache-Control: no-store, no-cache, must-revalidate
  X-Robots-Tag: noindex

# JS and CSS bundles (hashed by Vite)
/assets/*.js
  Cache-Control: public, max-age=31536000, immutable
/assets/*.css
  Cache-Control: public, max-age=31536000, immutable

# Default - moderate cache
/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400
