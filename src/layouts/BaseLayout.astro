---
import { ClientRouter } from "astro:transitions";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import type { Locale } from "../lib/i18n";
import "../styles/global.css";

interface Props {
    title: string;
    locale?: Locale;
    description?: string;
    image?: string;
}

const {
    title,
    locale = "en",
    description = "Handcrafted copper, brass & bronze kitchenware from Kathmandu",
    image,
} = Astro.props;
const currentPath = Astro.url.pathname;

const siteUrl = "https://metalhub.com.np";

const canonicalHref =
    locale === "en" ? `${siteUrl}${currentPath}` : `${siteUrl}${currentPath.replace(/^\/(ne|newa)/, "")}`;

const pageUrl = `${siteUrl}${currentPath}`;
const ogImage = image || `${siteUrl}/og-default.jpg`;
---

<!doctype html>
<html lang={locale} data-locale={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Metal Hub</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={`${title} — Metal Hub`} />
    <meta property="og:type" content="website" />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={ogImage} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalHref} />
    <link rel="alternate" hreflang="en" href={`${siteUrl}${currentPath.replace(/^\/(ne|newa)(\/|$)/, "/")}`} />
    <link rel="alternate" hreflang="ne" href={`${siteUrl}/ne${currentPath.replace(/^\/(ne|newa)?/, "")}`} />
    <link rel="alternate" hreflang="newa" href={`${siteUrl}/newa${currentPath.replace(/^\/(ne|newa)?/, "")}`} />
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}${currentPath.replace(/^\/(ne|newa)(\/|$)/, "/")}`} />
    <link rel="preconnect" href="https://connect.facebook.net" crossorigin />
    <link rel="preconnect" href="https://www.instagram.com" crossorigin />
    <link rel="preconnect" href="https://www.tiktok.com" crossorigin />
    <link rel="preconnect" href="https://tile.openstreetmap.org" crossorigin />
    <ClientRouter />
  </head>
  <body class="bg-surface-1 text-text-1 font-sans">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-3 focus:left-3 focus:z-[9999] focus:px-4 focus:py-2 focus:bg-white focus:text-accent focus:rounded-lg focus:shadow-lg focus:outline-none focus:ring-2 focus:ring-accent">Skip to main content</a>
    <Header locale={locale} currentPath={currentPath} />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer locale={locale} />

    <script is:inline>
      document.addEventListener("astro:page-load", function() {
        var m = window.location.pathname.match(/^\/(ne|newa)\//);
        var loc = m ? m[1] : "en";
        document.documentElement.lang = loc;
        document.documentElement.dataset.locale = loc;
      });
    </script>
  </body>
</html>
