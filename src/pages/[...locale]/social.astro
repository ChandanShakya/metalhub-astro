---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getTranslations, locales } from "../../lib/i18n";

export function getStaticPaths() {
    return locales.map((locale) => ({
        params: { locale: locale === "en" ? undefined : locale },
        props: { locale },
    }));
}

const { locale } = Astro.props;
const t = await getTranslations(locale);
---
<BaseLayout title={t("social.title")} locale={locale}>
  <!-- Warm connections for third-party embed scripts -->
  <link rel="preconnect" href="https://connect.facebook.net" />
  <link rel="preconnect" href="https://www.instagram.com" />
  <link rel="preconnect" href="https://www.tiktok.com" />
  <link rel="preconnect" href="https://cdn.tiktok.com" />

  <section class="py-8 px-4 sm:px-6 lg:px-8 max-w-4xl mx-auto">
    <h1 class="text-center mb-8 text-2xl sm:text-3xl font-extrabold">{t("social.title")}</h1>

    <div class="mb-10 sm:mb-12">
      <h2 class="text-lg sm:text-xl font-bold mb-4 flex items-center gap-2.5">
        {t("social.facebook")}
        <a href="https://www.facebook.com/profile.php?id=100092431583299" target="_blank" rel="noopener" class="text-xs sm:text-sm font-medium text-accent px-2 sm:px-2.5 py-1 border border-accent rounded-full transition-[colors,transform] hover:bg-accent hover:text-white hover:no-underline">
          {t("social.follow")} ↗
        </a>
      </h2>
      <div id="fb-page-plugin" class="w-full max-w-125 mx-auto relative" style="min-height:500px;">
        <div id="fb-root"></div>
        <div class="fb-page"
          data-href="https://www.facebook.com/profile.php?id=100092431583299"
          data-tabs="timeline"
          data-width="500"
          data-height="500"
          data-small-header="false"
          data-adapt-container-width="true"
          data-hide-cover="false"
          data-show-facepile="true">
        </div>
        <div class="skeleton absolute inset-0 z-10 rounded-lg" style="height:500px;"></div>
      </div>
    </div>

    <div class="mb-10 sm:mb-12">
      <h2 class="text-lg sm:text-xl font-bold mb-4 flex items-center gap-2.5">
        {t("social.instagram")}
        <a href="https://www.instagram.com/metal_hub.np" target="_blank" rel="noopener" class="text-xs sm:text-sm font-medium text-accent px-2 sm:px-2.5 py-1 border border-accent rounded-full transition-[colors,transform] hover:bg-accent hover:text-white hover:no-underline">
          {t("social.follow")} ↗
        </a>
      </h2>
      <div id="ig-container" class="w-full max-w-125 mx-auto relative" style="min-height:420px;">
        <blockquote class="instagram-media" data-instgrm-permalink="https://www.instagram.com/metal_hub.np/" data-instgrm-version="14" style="max-width:100%;min-width:unset;width:100%;"></blockquote>
        <div class="skeleton absolute inset-0 z-10 rounded-lg" style="height:420px;"></div>
      </div>
    </div>

    <div class="mb-10 sm:mb-12">
      <h2 class="text-lg sm:text-xl font-bold mb-4 flex items-center gap-2.5">
        {t("social.tiktok")}
        <a href="https://www.tiktok.com/@metalhub.np" target="_blank" rel="noopener" class="text-xs sm:text-sm font-medium text-accent px-2 sm:px-2.5 py-1 border border-accent rounded-full transition-[colors,transform] hover:bg-accent hover:text-white hover:no-underline">
          {t("social.follow")} ↗
        </a>
      </h2>
      <div id="tt-container" class="w-full max-w-125 mx-auto relative" style="min-height:480px;">
        <blockquote class="tiktok-embed" cite="https://www.tiktok.com/@metalhub.np" data-unique-id="metalhub.np" data-embed-from="embed_page" data-embed-type="creator" style="max-width:100%;min-width:288px;">
          <section>
            <a target="_blank" href="https://www.tiktok.com/@metalhub.np?refer=creator_embed">@metalhub.np</a>
          </section>
        </blockquote>
        <div class="skeleton absolute inset-0 z-10 rounded-lg" style="height:480px;"></div>
      </div>
    </div>
  </section>

  <script>
    import {
      loadFacebookSDK,
      loadInstagramSDK,
      loadTikTokSDK,
    } from "../../lib/social";

    var _socialLoaded = { fb: false, ig: false, tt: false };

    function hideSkeleton(container) {
      if (!container) return;
      var sk = container.querySelector(".skeleton");
      if (sk) sk.style.display = "none";
    }

    function initEmbed(elementId, loadFn) {
      var container = document.getElementById(elementId);
      if (!container) return;

      if (container.getBoundingClientRect().top < window.innerHeight + 200) {
        loadFn(container);
        return;
      }

      var observer = new IntersectionObserver(function(entries) {
        if (entries[0].isIntersecting) {
          observer.disconnect();
          loadFn(container);
        }
      }, { rootMargin: "200px" });
      observer.observe(container);
    }

    function loadFacebook(container) {
      if (_socialLoaded.fb) return;
      _socialLoaded.fb = true;
      loadFacebookSDK(function() {
        requestAnimationFrame(function() {
          try { FB.XFBML.parse(); } catch(e) {}
          hideSkeleton(container);
        });
      });
      setTimeout(function() { hideSkeleton(container); }, 3000);
    }

    function loadInstagram(container) {
      if (_socialLoaded.ig) return;
      _socialLoaded.ig = true;
      loadInstagramSDK(function() {
        requestAnimationFrame(function() {
          try { window.instgrm.Embeds.process(); } catch(e) {}
          hideSkeleton(container);
        });
      });
      setTimeout(function() { hideSkeleton(container); }, 3000);
    }

    function loadTikTok(container) {
      if (_socialLoaded.tt) return;
      _socialLoaded.tt = true;
      loadTikTokSDK(function() {
        requestAnimationFrame(function() {
          try { window.tiktok.embed(); } catch(e) {}
          hideSkeleton(container);
        });
      });
      setTimeout(function() { hideSkeleton(container); }, 3000);
    }

    document.addEventListener("astro:page-load", function() {
      _socialLoaded = { fb: false, ig: false, tt: false };
      initEmbed("fb-page-plugin", loadFacebook);
      initEmbed("ig-container", loadInstagram);
      initEmbed("tt-container", loadTikTok);
    });
  </script>
</BaseLayout>
