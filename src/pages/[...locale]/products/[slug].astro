---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import AttributeSelector from "../../../components/AttributeSelector.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getTranslations, locales } from "../../../lib/i18n";

export async function getStaticPaths() {
    const products = await getCollection("products");
    const paths = [];
    for (const locale of locales) {
        for (const product of products) {
            paths.push({
                params: { locale: locale === "en" ? undefined : locale, slug: product.data.slug },
                props: { product, locale },
            });
        }
    }
    return paths;
}

const { product, locale } = Astro.props;
const t = await getTranslations(locale);
const productName = product.data.name[locale as keyof typeof product.data.name] || product.data.name.en;
const description =
    product.data.description[locale as keyof typeof product.data.description] || product.data.description.en;
const productImages = product.data.images.length > 0 ? product.data.images : ["/images/products/placeholder.jpg"];

const schemaJson = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    name: productName,
    description: description,
    image: productImages,
    offers: {
        "@type": "Offer",
        price: product.data.basePrice,
        priceCurrency: "NPR",
        availability: product.data.inStock ? "https://schema.org/InStock" : "https://schema.org/OutOfStock",
    },
});
---

<BaseLayout title={productName} locale={locale} description={description} image={productImages[0]}>
  <script is:inline type="application/ld+json" set:html={schemaJson} />
  <section class="py-8 container mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-12">
      <div>
        <div id="main-image-wrapper" class="relative rounded-xl overflow-hidden bg-linear-to-br from-surface-3 to-border cursor-zoom-in" data-product-images={JSON.stringify(productImages)}>
          <Image id="main-image" src={productImages[0]} alt={productName} class="w-full aspect-square object-cover transition-transform duration-500 hover:scale-[1.02]" width={800} height={800} loading="eager" decoding="sync" />
        </div>

        <div class="relative mt-3">
          <button id="gallery-prev" class="absolute left-0 top-1/2 -translate-y-1/2 z-10 w-10 h-10 bg-surface-2/90 backdrop-blur-sm border border-border rounded-full flex items-center justify-center cursor-pointer shadow-md hover:bg-surface-3 transition-colors text-text-1 text-lg" aria-label="Previous image">&#8249;</button>
          <div id="gallery-track" class="flex gap-2 overflow-x-auto pb-1 scroll-smooth px-10">
            {productImages.map((img, i) => (
              <button class="gallery-thumb shrink-0 w-16 h-16 md:w-20 md:h-20 rounded-lg overflow-hidden border-2 border-border transition-[colors,transform] hover:border-accent cursor-pointer relative group" data-image={img} data-index={String(i)}>
                <Image src={img} alt={productName + " " + (i + 1)} class="w-full h-full object-cover" width={200} height={200} />
                <span class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors flex items-center justify-center">
                  <svg class="w-4 h-4 text-white opacity-0 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                </span>
              </button>
            ))}
          </div>
          <button id="gallery-next" class="absolute right-0 top-1/2 -translate-y-1/2 z-10 w-10 h-10 bg-surface-2/90 backdrop-blur-sm border border-border rounded-full flex items-center justify-center cursor-pointer shadow-md hover:bg-surface-3 transition-colors text-text-1 text-lg" aria-label="Next image">&#8250;</button>
        </div>
      </div>

      <div>
        <div class="flex items-center gap-3 mb-2">
          <h1 class="text-2xl font-bold flex-1">{productName}</h1>
          <button id="share-btn" class="w-10 h-10 flex items-center justify-center border border-border rounded-full text-text-2 hover:border-accent hover:text-accent transition-[colors,transform] cursor-pointer" aria-label="Share">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
          </button>
        </div>
        <p class="text-text-2 mb-6 leading-relaxed">{description}</p>

        <div id="product-discount-data" class="hidden">
          {JSON.stringify(product.data.discount)}
        </div>

        <AttributeSelector
          attributes={product.data.attributes}
          locale={locale}
          basePrice={product.data.basePrice}
          productSlug={product.data.slug}
          productName={productName}
          productNameAll={product.data.name}
          productImage={productImages[0]}
        />
      </div>
    </div>
  </section>

  {product.data.socialEmbeds && product.data.socialEmbeds.length > 0 && (
    <section id="product-social" class="py-8 container mx-auto px-4 border-t border-border">
      <h2 class="text-xl font-bold mb-6">{t("social.latestPosts")}</h2>
      <div class="flex flex-col items-center gap-8">
        {product.data.socialEmbeds.map((embed) => (
          <div class="w-full max-w-195 rounded-xl" data-social-embed={embed.platform} set:html={embed.embedCode} />
        ))}
      </div>
    </section>
  )}

  <div id="lightbox" class="hidden fixed inset-0 z-1000 bg-black/90 flex items-center justify-center p-4" tabindex="-1">
    <button id="lightbox-close" class="absolute top-4 right-4 text-white text-3xl font-bold cursor-pointer hover:text-accent transition-colors z-10" aria-label="Close">&times;</button>
    <button id="lightbox-prev" class="absolute left-4 top-1/2 -translate-y-1/2 text-white text-4xl cursor-pointer hover:text-accent transition-colors z-10" aria-label="Previous">&#8249;</button>
    <img id="lightbox-img" src="" alt={productName} class="max-w-full max-h-full object-contain rounded-lg" />
    <button id="lightbox-next" class="absolute right-4 top-1/2 -translate-y-1/2 text-white text-4xl cursor-pointer hover:text-accent transition-colors z-10" aria-label="Next">&#8250;</button>
    <div id="lightbox-counter" class="absolute bottom-4 left-1/2 -translate-x-1/2 text-white text-sm font-medium bg-black/50 px-3 py-1 rounded-full"></div>
  </div>

  <div id="share-popup" class="hidden fixed inset-0 z-1000 bg-black/50 flex items-center justify-center p-4">
    <div class="bg-surface-2 rounded-2xl shadow-2xl max-w-sm w-full p-6 relative">
      <button id="share-close" class="absolute top-3 right-3 w-8 h-8 flex items-center justify-center text-text-3 hover:text-text-1 rounded-full hover:bg-surface-3 transition-colors cursor-pointer" aria-label="Close">&times;</button>
      <h3 class="text-lg font-bold mb-4">{t("share.title")}</h3>
      <div class="flex items-center gap-3 mb-5">
        <Image id="share-preview-img" src={productImages[0]} alt={productName} class="w-16 h-16 rounded-lg object-cover" width={64} height={64} />
        <div>
          <p class="font-semibold text-sm">{productName}</p>
          <p class="text-accent-dark font-bold text-sm">NPR {product.data.basePrice.toLocaleString()}</p>
        </div>
      </div>
      <div class="space-y-2">
        <button id="share-whatsapp" class="w-full flex items-center gap-3 px-4 py-3 bg-whatsapp text-white rounded-xl font-medium text-sm transition-[colors,transform] hover:bg-[#1eac5a] hover:-translate-y-0.5 cursor-pointer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.076 3.2 5.021 4.488.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.822 11.822 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          {t("share.whatsapp")}
        </button>
        <button id="share-facebook" class="w-full flex items-center gap-3 px-4 py-3 bg-[#1877f2] text-white rounded-xl font-medium text-sm transition-[colors,transform] hover:bg-[#166fe5] hover:-translate-y-0.5 cursor-pointer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.481 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          {t("share.facebook")}
        </button>
        <button id="share-twitter" class="w-full flex items-center gap-3 px-4 py-3 bg-[#1da1f2] text-white rounded-xl font-medium text-sm transition-[colors,transform] hover:bg-[#0d8ecf] hover:-translate-y-0.5 cursor-pointer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/></svg>
          {t("share.twitter")}
        </button>
        <button id="share-copy" data-ui-text={JSON.stringify({ copied: t("share.copied") })} class="w-full flex items-center gap-3 px-4 py-3 bg-surface-3 text-text-1 border border-border rounded-xl font-medium text-sm transition-[colors,transform] hover:bg-surface-2 hover:-translate-y-0.5 cursor-pointer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
          <span id="share-copy-text">{t("share.copyLink")}</span>
        </button>
      </div>
    </div>
  </div>

  <script is:inline define:vars={{ productName }}>
    window.__galleryCtx = window.__galleryCtx || { id: 0, abort: null };
    var _galleryId = ++window.__galleryCtx.id;

    document.addEventListener("astro:page-load", function() {
      if (window.__galleryCtx.id !== _galleryId) return;
      if (!document.getElementById("main-image-wrapper")) return;
      if (window.__galleryCtx.abort) window.__galleryCtx.abort.abort();
      window.__galleryCtx.abort = new AbortController();
      var signal = window.__galleryCtx.abort.signal;

      var mainImage = document.getElementById("main-image");
      var lightboxImg = document.getElementById("lightbox-img");
      var lightbox = document.getElementById("lightbox");
      var counter = document.getElementById("lightbox-counter");
      var currentImages = [];
      var currentIndex = 0;

      function setMainImage(src) {
        if (mainImage) mainImage.src = src;
        if (lightboxImg) lightboxImg.src = src;
        document.querySelectorAll(".gallery-thumb").forEach(function(t) {
          var isActive = t.getAttribute("data-image") === src;
          t.classList.toggle("border-accent", isActive);
          t.classList.toggle("border-border", !isActive);
        });
      }

      function updateCounter() {
        if (counter && currentImages.length > 1) {
          counter.textContent = (currentIndex + 1) + " / " + currentImages.length;
          counter.classList.remove("hidden");
        } else if (counter) {
          counter.classList.add("hidden");
        }
      }

      function showImage(idx) {
        if (currentImages.length === 0) return;
        currentIndex = ((idx % currentImages.length) + currentImages.length) % currentImages.length;
        setMainImage(currentImages[currentIndex]);
        updateCounter();
      }

      document.querySelectorAll(".gallery-thumb").forEach(function(thumb) {
        thumb.addEventListener("click", function(e) {
          e.stopPropagation();
          var src = this.getAttribute("data-image");
          var idx = parseInt(this.getAttribute("data-index") || "0");
          currentIndex = idx;
          setMainImage(src);
          updateCounter();
        }, { signal: signal });
      });

      var prevBtn = document.getElementById("gallery-prev");
      var nextBtn = document.getElementById("gallery-next");
      if (prevBtn) prevBtn.addEventListener("click", function(e) { e.stopPropagation(); showImage(currentIndex - 1); }, { signal: signal });
      if (nextBtn) nextBtn.addEventListener("click", function(e) { e.stopPropagation(); showImage(currentIndex + 1); }, { signal: signal });

      var lbPrev = document.getElementById("lightbox-prev");
      var lbNext = document.getElementById("lightbox-next");
      if (lbPrev) lbPrev.addEventListener("click", function(e) { e.stopPropagation(); showImage(currentIndex - 1); }, { signal: signal });
      if (lbNext) lbNext.addEventListener("click", function(e) { e.stopPropagation(); showImage(currentIndex + 1); }, { signal: signal });

      var lastFocused = null;

      function openLightbox() {
        if (!lightbox) return;
        lastFocused = document.activeElement;
        lightbox.classList.remove("hidden");
        var closeBtn = document.getElementById("lightbox-close");
        if (closeBtn) closeBtn.focus();
      }

      function closeLightbox() {
        if (!lightbox) return;
        lightbox.classList.add("hidden");
        if (lastFocused) lastFocused.focus();
      }

      document.addEventListener("keydown", function(e) {
        if (lightbox && !lightbox.classList.contains("hidden")) {
          if (e.key === "ArrowLeft") showImage(currentIndex - 1);
          if (e.key === "ArrowRight") showImage(currentIndex + 1);
          if (e.key === "Escape") closeLightbox();
          if (e.key === "Tab") {
            var focusable = lightbox.querySelectorAll('button, [tabindex]:not([tabindex="-1"])');
            if (focusable.length === 0) return;
            var first = focusable[0];
            var last = focusable[focusable.length - 1];
            if (e.shiftKey) {
              if (document.activeElement === first) {
                e.preventDefault();
                last.focus();
              }
            } else {
              if (document.activeElement === last) {
                e.preventDefault();
                first.focus();
              }
            }
          }
        }
      }, { signal: signal });

      window.addEventListener("attribute-image-changed", function(e) {
        var imgs = e.detail?.images || [];
        if (imgs.length > 0) {
          currentImages = imgs;
          currentIndex = 0;
          setMainImage(imgs[0]);
          updateCounter();
        }
      }, { signal: signal });

      currentImages = JSON.parse(document.getElementById("main-image-wrapper")?.getAttribute("data-product-images") || "[]");
      if (currentImages.length > 0) setMainImage(currentImages[0]);
      updateCounter();

      var mainImageWrapper = document.getElementById("main-image-wrapper");
      if (mainImageWrapper) {
        mainImageWrapper.addEventListener("click", openLightbox, { signal: signal });
      }

      var lightboxClose = document.getElementById("lightbox-close");
      if (lightboxClose) {
        lightboxClose.addEventListener("click", closeLightbox, { signal: signal });
        lightboxClose.addEventListener("keydown", function(e) {
          if (e.key === "Enter" || e.key === " ") closeLightbox();
        }, { signal: signal });
      }

      if (lightbox) {
        lightbox.addEventListener("click", function(e) {
          if (e.target === lightbox) closeLightbox();
        }, { signal: signal });
      }

      var socialSection = document.getElementById("product-social");
      if (socialSection && !window.__socialLoaded) {
        var socialObserver = new IntersectionObserver(function(entries) {
          if (entries[0].isIntersecting) {
            socialObserver.disconnect();
            window.__socialLoaded = true;
            var loaded = {};
            socialSection.querySelectorAll("[data-social-embed]").forEach(function(el) {
              var platform = el.getAttribute("data-social-embed");
              if (loaded[platform]) return;
              loaded[platform] = true;
              if (platform === "tiktok") {
                var s = document.createElement("script");
                s.src = "https://www.tiktok.com/embed.js";
                s.async = true;
                document.head.appendChild(s);
              } else if (platform === "instagram") {
                var s = document.createElement("script");
                s.src = "https://www.instagram.com/embed.js";
                s.async = true;
                document.head.appendChild(s);
              } else if (platform === "facebook" && !window.FB) {
                window.fbAsyncInit = function() { FB.init({ xfbml: true, version: "v19.0" }); };
                var s = document.createElement("script");
                s.src = "https://connect.facebook.net/en_US/sdk.js";
                s.async = true;
                document.head.appendChild(s);
              }
            });
          }
        }, { rootMargin: "200px" });
        socialObserver.observe(socialSection);
      }

      var shareBtn = document.getElementById("share-btn");
      var sharePopup = document.getElementById("share-popup");
      var shareClose = document.getElementById("share-close");
      if (shareBtn && sharePopup) {
        shareBtn.addEventListener("click", function(e) {
          e.stopPropagation();
          sharePopup.classList.remove("hidden");
          var shareImg = document.getElementById("share-preview-img");
          if (shareImg && mainImage) shareImg.src = mainImage.src;
        }, { signal: signal });

        if (shareClose) shareClose.addEventListener("click", function(e) {
          e.stopPropagation();
          sharePopup.classList.add("hidden");
        }, { signal: signal });

        sharePopup.addEventListener("click", function(e) {
          if (e.target === sharePopup) sharePopup.classList.add("hidden");
        }, { signal: signal });

        var shareWhatsapp = document.getElementById("share-whatsapp");
        var shareFacebook = document.getElementById("share-facebook");
        var shareTwitter = document.getElementById("share-twitter");
        var shareCopy = document.getElementById("share-copy");

        function getShareUrl() {
          var params = new URLSearchParams(window.location.search);
          var path = window.location.pathname;
          return window.location.origin + path + (params.toString() ? "?" + params.toString() : "");
        }

        function getShareText() {
          return productName + " \u2014 Metal Hub";
        }

        if (shareWhatsapp) shareWhatsapp.addEventListener("click", function() {
          window.open("https://wa.me/?text=" + encodeURIComponent(getShareText() + "\n" + getShareUrl()), "_blank");
        }, { signal: signal });

        if (shareFacebook) shareFacebook.addEventListener("click", function() {
          window.open("https://www.facebook.com/sharer/sharer.php?u=" + encodeURIComponent(getShareUrl()), "_blank", "width=600,height=400");
        }, { signal: signal });

        if (shareTwitter) shareTwitter.addEventListener("click", function() {
          window.open("https://twitter.com/intent/tweet?text=" + encodeURIComponent(getShareText()) + "&url=" + encodeURIComponent(getShareUrl()), "_blank", "width=600,height=400");
        }, { signal: signal });

        if (shareCopy) shareCopy.addEventListener("click", function() {
          var shareUiText = JSON.parse(shareCopy.getAttribute("data-ui-text") || "{}");
          navigator.clipboard.writeText(getShareUrl()).then(function() {
            var copyText = document.getElementById("share-copy-text");
            if (copyText) {
              var orig = copyText.textContent;
              copyText.textContent = shareUiText.copied || "Copied!";
              setTimeout(function() { copyText.textContent = orig; }, 2000);
            }
          });
        }, { signal: signal });
      }
    });
  </script>
</BaseLayout>
