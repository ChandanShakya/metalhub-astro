---
import { getCollection } from "astro:content";
import ProductCard from "../../../components/ProductCard.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getTranslations, locales } from "../../../lib/i18n";
import { calculateVariantPrice, getItemStock, isSaleActive, resolveAttributeLabels } from "../../../lib/pricing";

export function getStaticPaths() {
    return locales.map((locale) => ({
        params: { locale: locale === "en" ? undefined : locale },
        props: { locale },
    }));
}

const { locale } = Astro.props;
const t = await getTranslations(locale);

const PER_PAGE = 9;

const products = await getCollection("products");
const categories = await getCollection("categories");
const materials = await getCollection("materials");
const sortedCategories = categories.sort((a, b) => a.data.order - b.data.order);
const sortedMaterials = materials.sort((a, b) => a.data.order - b.data.order);

const categoryMap = new Map(categories.map((c) => [c.data.slug, c.data.name]));
const materialMap = new Map(materials.map((m) => [m.data.slug, m.data.name]));

const categoryCounts = new Map<string, number>();
const materialCounts = new Map<string, number>();
for (const p of products) {
    categoryCounts.set(p.data.category, (categoryCounts.get(p.data.category) || 0) + 1);
    materialCounts.set(p.data.material, (materialCounts.get(p.data.material) || 0) + 1);
}

const productStatsData = products.map((p) => ({
    category: p.data.category,
    material: p.data.material,
    slug: p.data.slug,
    v: p.data.variants?.length || 0,
    stock: p.data.variants?.length > 0 ? p.data.variants.reduce((s, v) => s + (v.stock ?? 0), 0) : (p.data.stock ?? 0),
}));

const categoryStockCounts = new Map<string, number>();
const materialStockCounts = new Map<string, number>();
for (const p of productStatsData) {
    const ext = categoryStockCounts.get(p.category) || 0;
    categoryStockCounts.set(p.category, ext + p.stock);
    const exm = materialStockCounts.get(p.material) || 0;
    materialStockCounts.set(p.material, exm + p.stock);
}
const totalStock = productStatsData.reduce((s, p) => s + p.stock, 0);

const saleTypes = new Set<string>();
let hasAnyActiveSale = false;
for (const product of products) {
    if (isSaleActive(product.data.discount)) {
        hasAnyActiveSale = true;
        if (product.data.discount.saleType) {
            saleTypes.add(product.data.discount.saleType);
        }
    }
    for (const variant of product.data.variants) {
        if (isSaleActive(variant.discount)) {
            hasAnyActiveSale = true;
            if (variant.discount.saleType) {
                saleTypes.add(variant.discount.saleType);
            }
        }
    }
}
const sortedSaleTypes = Array.from(saleTypes).sort();

const productStatsJSON = JSON.stringify(productStatsData);

interface ProductItem {
    product: (typeof products)[number];
    variant: (typeof products)[number]["data"]["variants"][number] | null;
    price: number;
    originalPrice: number;
    hasDiscount: boolean;
    discountLabel: string;
    variantParams: string;
    attributeLabels: Record<string, string> | null;
    stock: number;
    saleType?: string;
    eventName?: string;
}

const productItems: ProductItem[] = products.flatMap((product) => {
    const base = product.data.basePrice;
    const variants = product.data.variants;
    const images = product.data.images;

    if (!variants || variants.length === 0) {
        const active = isSaleActive(product.data.discount);
        const discounted = active
            ? product.data.discount.type === "percentage"
                ? Math.round(base * (1 - product.data.discount.value / 100))
                : Math.max(0, base - product.data.discount.value)
            : base;
        const label = active
            ? product.data.discount.type === "percentage"
                ? `${product.data.discount.value}% off`
                : `NPR ${product.data.discount.value} off`
            : "";
        return [
            {
                product,
                variant: null,
                price: discounted,
                originalPrice: base,
                hasDiscount: active,
                discountLabel: label,
                variantParams: "",
                attributeLabels: null,
                stock: product.data.stock ?? 0,
                saleType: active ? product.data.discount.saleType : undefined,
                eventName: active ? product.data.discount.eventName : undefined,
            },
        ];
    }

    return variants.map((variant) => {
        const total = base + variant.priceModifier;
        const result = calculateVariantPrice(base, variant);
        const labels = product.data.attributeGroups
            ? resolveAttributeLabels(product.data.attributeGroups, locale, variant.attributeValues)
            : {};
        const params = new URLSearchParams();
        for (const av of variant.attributeValues) {
            params.set(av.group, av.option);
        }
        return {
            product,
            variant,
            price: result.discountedPrice,
            originalPrice: result.originalPrice,
            hasDiscount: result.hasDiscount,
            discountLabel: result.discountLabel,
            variantParams: params.toString(),
            attributeLabels: labels,
            stock: variant.stock ?? 0,
            saleType: result.hasDiscount ? variant.discount.saleType || product.data.discount.saleType : undefined,
            eventName: result.hasDiscount ? variant.discount.eventName || product.data.discount.eventName : undefined,
        };
    });
});

const totalItemPages = Math.ceil(productItems.length / PER_PAGE);
---
<BaseLayout title={t("products.title")} locale={locale}>
  <section class="py-8 container mx-auto px-4">

    {productItems.length === 0 ? (
      <p class="text-center py-12 text-text-3">{t("products.noProducts")}</p>
    ) : (
      <>
        {sortedCategories.length > 0 && (
          <div class="flex gap-2 flex-wrap mb-3">
            <button class="filter-btn group active bg-surface-2 border border-border rounded-full px-3.5 py-1.5 cursor-pointer text-sm font-medium transition-[colors,transform] text-text-2 hover:border-accent hover:text-accent" data-filter-type="category" data-category="all" aria-pressed="true">{t("products.all")} <span class="count-badge text-[0.6rem] font-bold px-1.5 py-0.5 rounded-full bg-surface-3 text-text-2 leading-none ml-1">{totalStock}</span></button>
            {sortedCategories.map((cat) => (
              <button class="filter-btn group bg-surface-2 border border-border rounded-full px-3.5 py-1.5 cursor-pointer text-sm font-medium transition-[colors,transform] text-text-2 hover:border-accent hover:text-accent" data-filter-type="category" data-category={cat.data.slug} aria-pressed="false">
                {cat.data.icon} {cat.data.name[locale as keyof typeof cat.data.name] || cat.data.name.en} <span class="count-badge text-[0.6rem] font-bold px-1.5 py-0.5 rounded-full bg-surface-3 text-text-2 leading-none ml-1">{categoryStockCounts.get(cat.data.slug) ?? 0}</span>
              </button>
            ))}
          </div>
        )}
        {sortedMaterials.length > 0 && (
          <div class="flex gap-2 flex-wrap mb-3">
            <button class="filter-btn group active bg-surface-2 border border-border rounded-full px-3.5 py-1.5 cursor-pointer text-sm font-medium transition-[colors,transform] text-text-2 hover:border-accent hover:text-accent" data-filter-type="material" data-material="all" aria-pressed="true">{t("products.all")} <span class="count-badge text-[0.6rem] font-bold px-1.5 py-0.5 rounded-full bg-surface-3 text-text-2 leading-none ml-1">{totalStock}</span></button>
            {sortedMaterials.map((mat) => (
              <button class="filter-btn group bg-surface-2 border border-border rounded-full px-3.5 py-1.5 cursor-pointer text-sm font-medium transition-[colors,transform] text-text-2 hover:border-accent hover:text-accent" data-filter-type="material" data-material={mat.data.slug} aria-pressed="false">
                {mat.data.name[locale as keyof typeof mat.data.name] || mat.data.name.en} <span class="count-badge text-[0.6rem] font-bold px-1.5 py-0.5 rounded-full bg-surface-3 text-text-2 leading-none ml-1">{materialStockCounts.get(mat.data.slug) ?? 0}</span>
              </button>
            ))}
          </div>
        )}
        {hasAnyActiveSale && (() => {
            const onSaleStock = productItems.filter(item => item.hasDiscount).reduce((sum, item) => sum + item.stock, 0);
            const saleTypeStock = new Map<string, number>();
            for (const item of productItems) {
                if (item.hasDiscount && item.saleType) {
                    saleTypeStock.set(item.saleType, (saleTypeStock.get(item.saleType) || 0) + item.stock);
                }
            }
            return (
                <div class="mb-3">
                    <div class="flex gap-2 flex-wrap mb-2">
                        <button class="filter-btn group active bg-surface-2 border border-border rounded-full px-3.5 py-1.5 cursor-pointer text-sm font-medium transition-[colors,transform] text-text-2 hover:border-accent hover:text-accent" data-filter-type="sale-event" data-sale-event="all" aria-pressed="true">
                            {t("products.all")} <span class="count-badge text-[0.6rem] font-bold px-1.5 py-0.5 rounded-full bg-surface-3 text-text-2 leading-none ml-1">{totalStock}</span>
                        </button>
                        <button class="filter-btn group bg-surface-2 border border-border rounded-full px-3.5 py-1.5 cursor-pointer text-sm font-medium transition-[colors,transform] text-text-2 hover:border-accent hover:text-accent" data-filter-type="sale-event" data-sale-event="on-sale" aria-pressed="false">
                            🔥 {t("products.onSale")} <span class="count-badge text-[0.6rem] font-bold px-1.5 py-0.5 rounded-full bg-surface-3 text-text-2 leading-none ml-1">{onSaleStock}</span>
                        </button>
                    </div>
                    <div id="sale-type-filters" class="hidden flex gap-2 flex-wrap">
                        <button class="sale-type-btn filter-btn group active bg-surface-2 border border-border rounded-full px-3.5 py-1.5 cursor-pointer text-sm font-medium transition-[colors,transform] text-text-2 hover:border-accent hover:text-accent" data-filter-type="sale-type" data-sale-type="" aria-pressed="true">
                            {t("products.all")} <span class="count-badge text-[0.6rem] font-bold px-1.5 py-0.5 rounded-full bg-surface-3 text-text-2 leading-none ml-1">{onSaleStock}</span>
                        </button>
                        {sortedSaleTypes.map((saleType) => (
                            <button class="sale-type-btn filter-btn group bg-surface-2 border border-border rounded-full px-3.5 py-1.5 cursor-pointer text-sm font-medium transition-[colors,transform] text-text-2 hover:border-accent hover:text-accent" data-filter-type="sale-type" data-sale-type={saleType} aria-pressed="false">
                                🏷️ {saleType} <span class="count-badge text-[0.6rem] font-bold px-1.5 py-0.5 rounded-full bg-surface-3 text-text-2 leading-none ml-1">{saleTypeStock.get(saleType) || 0}</span>
                            </button>
                        ))}
                    </div>
                </div>
            );
        })()}

        <div id="category-stats" class="text-xs text-text-3 mb-4 px-1 leading-relaxed" data-ui-text={JSON.stringify({ stats: t("products.stats") })}></div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 lg:gap-6" id="product-grid" data-per-page={String(PER_PAGE)}>
          {productItems.map((item, i) => {
            const pageNum = Math.floor(i / PER_PAGE) + 1;
            const catName = categoryMap.get(item.product.data.category);
            const matName = materialMap.get(item.product.data.material);
            return (
              <div class:list={["product-item", { "hidden": pageNum > 1 }]} data-category={item.product.data.category} data-material={item.product.data.material} data-sale-event={item.saleType || (item.hasDiscount ? "on-sale" : "")} data-page={String(pageNum)}>
                <ProductCard
                  slug={item.product.data.slug}
                  name={item.product.data.name[locale as keyof typeof item.product.data.name] || item.product.data.name.en}
                  category={item.product.data.category}
                  material={item.product.data.material}
                  categoryName={catName ? (catName[locale as keyof typeof catName] || catName.en) : undefined}
                  materialName={matName ? (matName[locale as keyof typeof matName] || matName.en) : undefined}
                  image={(item.variant && item.variant.images && item.variant.images[0]) || item.product.data.images[0] || "/images/products/placeholder.jpg"}
                  price={item.price}
                  originalPrice={item.originalPrice}
                  hasDiscount={item.hasDiscount}
                  discountLabel={item.discountLabel}
                  inStock={item.variant ? item.variant.inStock : item.product.data.inStock}
                  stock={item.stock}
                  locale={locale}
                  variantParams={item.variantParams || undefined}
                  attributeLabels={item.attributeLabels || undefined}
                  saleType={item.saleType}
                  eventName={item.eventName}
                />
              </div>
            );
          })}
        </div>

        {totalItemPages > 1 && (
          <div class="text-center mt-8">
            <button id="load-more-btn" data-ui-text={JSON.stringify({ loadMore: t("products.loadMore"), showing: t("products.showing") })} class="bg-surface-2 border border-border rounded-xl px-6 py-3 text-sm font-semibold cursor-pointer transition-[colors,transform] text-text-2 hover:border-accent hover:text-accent hover:bg-surface-3">
              {t("products.loadMore")}
            </button>
            <p id="load-more-info" aria-live="polite" class="text-xs text-text-3 mt-2"></p>
          </div>
        )}
      </>
    )}
  </section>

  <div id="category-stats-data" data-stats={productStatsJSON} class="hidden" aria-hidden="true"></div>

  <style>
    .filter-btn.active:hover {
      color: white !important;
      border-color: rgba(255, 255, 255, 0.3) !important;
    }
    .filter-btn.active:hover .count-badge {
      background-color: rgba(255, 255, 255, 0.2) !important;
      color: white !important;
    }
  </style>

  <script>
    window.__productsCtx = window.__productsCtx || { id: 0, abort: null };
    var _productsId = ++window.__productsCtx.id;

    function updateCategoryStats() {
      var statsEl = document.getElementById("category-stats");
      if (!statsEl) return;
      var dataEl = document.getElementById("category-stats-data");
      if (!dataEl) return;
      var allStats = JSON.parse(dataEl.getAttribute("data-stats") || "[]");
      var productItems = document.querySelectorAll(".product-item");
      var activeCat = document.querySelector('.filter-btn.active[data-filter-type="category"]') as HTMLButtonElement | null;
      var activeMat = document.querySelector('.filter-btn.active[data-filter-type="material"]') as HTMLButtonElement | null;
      var activeEvent = document.querySelector('.filter-btn.active[data-filter-type="sale-event"]') as HTMLButtonElement | null;
      var activeSaleType = document.querySelector('.sale-type-btn.active') as HTMLButtonElement | null;
      var cat = activeCat?.dataset.category || "all";
      var mat = activeMat?.dataset.material || "all";
      var saleEvent = activeEvent?.dataset.saleEvent || "all";
      var saleType = activeSaleType?.dataset.saleType || "";

      var slugs = new Set<string>();
      var materials = new Set<string>();
      var variantCount = 0;
      var totalStock = 0;
      var catMatStock: Record<string, number> = {};

      for (var i = 0; i < allStats.length; i++) {
        var key = allStats[i].category + "|" + allStats[i].material;
        catMatStock[key] = (catMatStock[key] || 0) + allStats[i].stock;
      }

      productItems.forEach(function(item) {
        var el = item as HTMLElement;
        if (el.classList.contains("hidden")) return;
        var matchCat = cat === "all" || el.dataset.category === cat;
        var matchMat = mat === "all" || el.dataset.material === mat;
        var matchSale = saleEvent === "all" || el.dataset.saleEvent !== "";
        if (saleEvent === "on-sale" && saleType) {
          matchSale = el.dataset.saleEvent === saleType;
        }
        if (matchCat && matchMat && matchSale) {
          slugs.add(el.dataset.category + "|" + el.dataset.material);
          materials.add(el.dataset.material || "");
          variantCount++;
        }
      });

      slugs.forEach(function(key) {
        totalStock += catMatStock[key] || 0;
      });

      var statsText = JSON.parse(statsEl.getAttribute("data-ui-text") || "{}");
      statsEl.textContent = (statsText.stats || "{0} products · {1} materials · {2} variants · {3} in stock")
        .replace("{0}", slugs.size)
        .replace("{1}", materials.size)
        .replace("{2}", variantCount)
        .replace("{3}", totalStock);
    }

    function updateFilterCounts() {
      var dataEl = document.getElementById("category-stats-data");
      if (!dataEl) return;
      var allStats = JSON.parse(dataEl.getAttribute("data-stats") || "[]");
      var activeCat = document.querySelector('.filter-btn.active[data-filter-type="category"]') as HTMLButtonElement | null;
      var activeMat = document.querySelector('.filter-btn.active[data-filter-type="material"]') as HTMLButtonElement | null;
      var activeEvent = document.querySelector('.filter-btn.active[data-filter-type="sale-event"]') as HTMLButtonElement | null;
      var activeSaleType = document.querySelector('.sale-type-btn.active') as HTMLButtonElement | null;
      var cat = activeCat?.dataset.category || "all";
      var mat = activeMat?.dataset.material || "all";
      var saleEvent = activeEvent?.dataset.saleEvent || "all";
      var saleType = activeSaleType?.dataset.saleType || "";

      var statsMap: Record<string, number> = {};
      for (var i = 0; i < allStats.length; i++) {
        var p = allStats[i];
        var key = p.category + "|" + p.material;
        statsMap[key] = (statsMap[key] || 0) + p.stock;
      }

      var productItems = document.querySelectorAll(".product-item");
      var saleCatStock: Record<string, number> = {};
      var saleMatStock: Record<string, number> = {};

      productItems.forEach(function(item) {
        var el = item as HTMLElement;
        var pCat = el.dataset.category || "";
        var pMat = el.dataset.material || "";
        var pSale = el.dataset.saleEvent || "";
        var key = pCat + "|" + pMat;
        var stock = statsMap[key] || 0;

        var matchSale = saleEvent === "all" || pSale !== "";
        if (saleEvent === "on-sale" && saleType) {
          matchSale = pSale === saleType;
        }

        if (matchSale) {
          saleCatStock[pCat] = (saleCatStock[pCat] || 0) + stock;
          saleMatStock[pMat] = (saleMatStock[pMat] || 0) + stock;
        }
      });

      document.querySelectorAll('.filter-btn[data-filter-type="material"]').forEach(function(btn) {
        var btnMat = btn.dataset.material;
        var stock = 0;
        if (btnMat === "all") {
          for (var k in saleMatStock) {
            if (mat === "all" || k === mat) stock += saleMatStock[k];
          }
        } else {
          stock = saleMatStock[btnMat] || 0;
        }
        var badge = btn.querySelector(".count-badge");
        if (badge) badge.textContent = stock;
      });

      document.querySelectorAll('.filter-btn[data-filter-type="category"]').forEach(function(btn) {
        var btnCat = btn.dataset.category;
        var stock = 0;
        if (btnCat === "all") {
          for (var k in saleCatStock) {
            if (cat === "all" || k === cat) stock += saleCatStock[k];
          }
        } else {
          stock = saleCatStock[btnCat] || 0;
        }
        var badge = btn.querySelector(".count-badge");
        if (badge) badge.textContent = stock;
      });
    }

    function applyFilters() {
      var grid = document.getElementById("product-grid");
      var perPage = parseInt(grid?.getAttribute("data-per-page") || "9");
      var currentPage = parseInt(grid?.getAttribute("data-page") || "1");

      var activeCat = document.querySelector('.filter-btn.active[data-filter-type="category"]') as HTMLButtonElement | null;
      var activeMat = document.querySelector('.filter-btn.active[data-filter-type="material"]') as HTMLButtonElement | null;
      var activeEvent = document.querySelector('.filter-btn.active[data-filter-type="sale-event"]') as HTMLButtonElement | null;
      var activeSaleType = document.querySelector('.sale-type-btn.active') as HTMLButtonElement | null;
      var cat = activeCat?.dataset.category || "all";
      var mat = activeMat?.dataset.material || "all";
      var saleEvent = activeEvent?.dataset.saleEvent || "all";
      var saleType = activeSaleType?.dataset.saleType || "";

      var visibleCount = 0;
      var totalMatch = 0;
      document.querySelectorAll(".product-item").forEach(item => {
        var el = item as HTMLElement;
        var matchCat = cat === "all" || el.dataset.category === cat;
        var matchMat = mat === "all" || el.dataset.material === mat;
        var matchEvent = saleEvent === "all" || el.dataset.saleEvent !== "";
        if (saleEvent === "on-sale") {
          if (saleType) {
            matchEvent = el.dataset.saleEvent === saleType;
          } else {
            matchEvent = el.dataset.saleEvent !== "";
          }
        }
        var match = matchCat && matchMat && matchEvent;
        if (match) totalMatch++;
        if (match) {
          visibleCount++;
          if (visibleCount <= perPage * currentPage) {
            el.classList.remove("hidden");
          } else {
            el.classList.add("hidden");
          }
        } else {
          el.classList.add("hidden");
        }
      });

      var params = new URLSearchParams(window.location.search);
      if (cat === "all") params.delete("category"); else params.set("category", cat);
      if (mat === "all") params.delete("material"); else params.set("material", mat);
      if (saleEvent === "all") params.delete("sale"); else params.set("sale", saleEvent);
      var newUrl = window.location.pathname + (params.toString() ? "?" + params.toString() : "");
      history.replaceState(null, "", newUrl);

      updateCategoryStats();
      updateFilterCounts();

      var loadMoreBtn = document.getElementById("load-more-btn");
      if (loadMoreBtn) {
        loadMoreBtn.classList.toggle("hidden", visibleCount <= perPage * currentPage);
      }
      var loadMoreInfo = document.getElementById("load-more-info");
      if (loadMoreInfo) {
        var loadMoreBtnEl = document.getElementById("load-more-btn");
        var uiText = loadMoreBtnEl ? JSON.parse(loadMoreBtnEl.getAttribute("data-ui-text") || "{}") : {};
        loadMoreInfo.textContent = (uiText.showing || "Showing {v} of {t} products").replace("{v}", String(Math.min(visibleCount, perPage * currentPage))).replace("{t}", String(totalMatch));
      }
    }

    function initFiltersAndPagination() {
      if (window.__productsCtx.abort) window.__productsCtx.abort.abort();
      window.__productsCtx.abort = new AbortController();
      var signal = window.__productsCtx.abort.signal;

      var grid = document.getElementById("product-grid");
      var perPage = parseInt(grid?.getAttribute("data-per-page") || "9");
      var currentPage = 1;
      if (grid) grid.setAttribute("data-page", "1");

      var filterGroups = ["category", "material", "sale-event"];

      filterGroups.forEach(function(type) {
        document.querySelectorAll('.filter-btn[data-filter-type="' + type + '"]').forEach(function(btn) {
          btn.addEventListener("click", function(this: HTMLButtonElement) {
            document.querySelectorAll('.filter-btn[data-filter-type="' + type + '"]').forEach(function(b) {
              b.classList.remove("active", "bg-accent", "text-white", "border-accent");
              b.classList.add("bg-surface-2", "text-text-2", "border-border");
              b.setAttribute("aria-pressed", "false");
              var badge = b.querySelector(".count-badge");
              if (badge) {
                badge.classList.remove("bg-white/20", "text-white");
                badge.classList.add("bg-surface-3", "text-text-2");
              }
            });
            this.classList.add("active", "bg-accent", "text-white", "border-accent");
            this.classList.remove("bg-surface-2", "text-text-2", "border-border");
            this.setAttribute("aria-pressed", "true");
            var thisBadge = this.querySelector(".count-badge");
            if (thisBadge) {
              thisBadge.classList.remove("bg-surface-3", "text-text-2");
              thisBadge.classList.add("bg-white/20", "text-white");
            }

            if (type === "sale-event") {
              var saleTypeFilters = document.getElementById("sale-type-filters");
              if (saleTypeFilters) {
                if (this.dataset.saleEvent === "on-sale") {
                  saleTypeFilters.classList.remove("hidden");
                  saleTypeFilters.classList.add("flex");
                  document.querySelectorAll('.sale-type-btn').forEach(function(b) {
                    b.classList.remove("active", "bg-accent", "text-white", "border-accent");
                    b.classList.add("bg-surface-2", "text-text-2", "border-border");
                    b.setAttribute("aria-pressed", "false");
                  });
                  var allSaleTypeBtn = saleTypeFilters.querySelector('[data-sale-type=""]') as HTMLButtonElement | null;
                  if (allSaleTypeBtn) {
                    allSaleTypeBtn.classList.add("active", "bg-accent", "text-white", "border-accent");
                    allSaleTypeBtn.classList.remove("bg-surface-2", "text-text-2", "border-border");
                    allSaleTypeBtn.setAttribute("aria-pressed", "true");
                  }
                } else {
                  saleTypeFilters.classList.add("hidden");
                  saleTypeFilters.classList.remove("flex");
                }
              }
            }

            currentPage = 1;
            grid?.setAttribute("data-page", "1");
            applyFilters();
          }, { signal });
        });
      });

      document.querySelectorAll('.sale-type-btn').forEach(function(btn) {
        btn.addEventListener("click", function(this: HTMLButtonElement) {
          document.querySelectorAll('.sale-type-btn').forEach(function(b) {
            b.classList.remove("active", "bg-accent", "text-white", "border-accent");
            b.classList.add("bg-surface-2", "text-text-2", "border-border");
            b.setAttribute("aria-pressed", "false");
          });
          this.classList.add("active", "bg-accent", "text-white", "border-accent");
          this.classList.remove("bg-surface-2", "text-text-2", "border-border");
          this.setAttribute("aria-pressed", "true");

          currentPage = 1;
          grid?.setAttribute("data-page", "1");
          applyFilters();
        }, { signal });
      });

      var loadMoreBtn = document.getElementById("load-more-btn");
      if (loadMoreBtn) {
        loadMoreBtn.addEventListener("click", function() {
          currentPage++;
          grid?.setAttribute("data-page", String(currentPage));

          var activeCat = document.querySelector('.filter-btn.active[data-filter-type="category"]') as HTMLButtonElement | null;
          var activeMat = document.querySelector('.filter-btn.active[data-filter-type="material"]') as HTMLButtonElement | null;
          var activeEvent = document.querySelector('.filter-btn.active[data-filter-type="sale-event"]') as HTMLButtonElement | null;
          var activeSaleType = document.querySelector('.sale-type-btn.active') as HTMLButtonElement | null;
          var cat = activeCat?.dataset.category || "all";
          var mat = activeMat?.dataset.material || "all";
          var saleEvent = activeEvent?.dataset.saleEvent || "all";
          var saleType = activeSaleType?.dataset.saleType || "";

          var visibleCount = 0;
          document.querySelectorAll(".product-item").forEach(function(item) {
            var el = item as HTMLElement;
            var matchCat = cat === "all" || el.dataset.category === cat;
            var matchMat = mat === "all" || el.dataset.material === mat;
            var matchEvent = saleEvent === "all" || el.dataset.saleEvent !== "";
            if (saleEvent === "on-sale") {
              if (saleType) {
                matchEvent = el.dataset.saleEvent === saleType;
              } else {
                matchEvent = el.dataset.saleEvent !== "";
              }
            }
            if (matchCat && matchMat && matchEvent) {
              visibleCount++;
              if (visibleCount <= perPage * currentPage) {
                el.classList.remove("hidden");
              }
            }
          });

          var totalVisible = document.querySelectorAll(".product-item:not(.hidden)").length;
          var totalMatch = document.querySelectorAll(".product-item").length;
          if (loadMoreBtn && visibleCount <= perPage * currentPage) {
            loadMoreBtn.classList.add("hidden");
          }
          var loadMoreInfo = document.getElementById("load-more-info");
          if (loadMoreInfo) {
            var loadMoreBtnEl = document.getElementById("load-more-btn");
            var uiText = loadMoreBtnEl ? JSON.parse(loadMoreBtnEl.getAttribute("data-ui-text") || "{}") : {};
            loadMoreInfo.textContent = (uiText.showing || "Showing {v} of {t} products").replace("{v}", String(totalVisible)).replace("{t}", String(totalMatch));
          }
        }, { signal });
      }

      var urlParams = new URLSearchParams(window.location.search);
      var initialCat = urlParams.get("category") || "all";
      var initialMat = urlParams.get("material") || "all";
      var initialEvent = urlParams.get("sale") || "all";
      var catBtn = document.querySelector('.filter-btn[data-category="' + initialCat + '"]') as HTMLButtonElement | null;
      if (catBtn) catBtn.click();
      var matBtn = document.querySelector('.filter-btn[data-material="' + initialMat + '"]') as HTMLButtonElement | null;
      if (matBtn) matBtn.click();
      var eventBtn = document.querySelector('.filter-btn[data-sale-event="' + initialEvent + '"]') as HTMLButtonElement | null;
      if (eventBtn) eventBtn.click();
    }

    document.addEventListener("astro:page-load", function() {
      if (window.__productsCtx.id !== _productsId) return;
      initFiltersAndPagination();
    });
  </script>
</BaseLayout>
