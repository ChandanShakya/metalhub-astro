---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getTranslations } from '../../lib/i18n';

const locale = 'ne';
const t = getTranslations(locale);

const products = await getCollection('products');
const categories = await getCollection('categories');
const sortedCategories = categories.sort((a, b) => a.data.order - b.data.order);
const featured = products.filter(p => p.data.featured && p.data.inStock).slice(0, 4);
---
<BaseLayout title={t('hero.title')} locale={locale}>
  <section class="hero">
    <h1>{t('hero.title')}</h1>
    <p>{t('hero.subtitle')}</p>
    <a href="/ne/products/" class="btn">{t('hero.cta')}</a>
  </section>

  {featured.length > 0 && (
    <section class="products-section container">
      <h2>{t('products.title')}</h2>
      <div class="product-grid">
        {featured.map((product) => (
          <a href={`/ne/products/${product.data.slug}/`} class="product-card">
            <img src={product.data.images[0] || '/images/products/placeholder.jpg'} alt={product.data.name.ne} class="product-card-img" loading="lazy" />
            <div class="product-card-body">
              <h3>{product.data.name.ne}</h3>
              <div class="category">{product.data.category}</div>
              <div class="price">NPR {product.data.basePrice.toLocaleString()}</div>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  {sortedCategories.length > 0 && (
    <section class="products-section container">
      <h2>{t('products.title')}</h2>
      <div class="product-grid">
        {sortedCategories.map((cat) => (
          <a href={`/ne/products/?category=${cat.data.slug}`} class="product-card" style="text-decoration:none;color:inherit;">
            <div class="product-card-body" style="text-align:center;padding:2rem;">
              <div style="font-size:2.5rem;">{cat.data.icon}</div>
              <p style="margin-top:0.5rem;font-weight:600;">{cat.data.name.ne}</p>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}
</BaseLayout>
