---
import { getTranslations, type Locale } from "../lib/i18n";

interface Props {
    showCheckoutLink?: boolean;
    locale: Locale;
}
const { showCheckoutLink = true, locale } = Astro.props;
const t = getTranslations(locale);
---

<div id="cart-widget" data-ui-text={JSON.stringify({
    title: t("cart.title"),
    empty: t("cart.empty"),
    subtotal: t("cart.subtotal"),
    checkout: t("cart.checkout"),
    clearAll: t("cart.clearAll"),
    noImg: t("cart.noImg"),
})}>
  <div class="mx-auto max-w-site px-4 py-8">
    <h2 id="cart-title" class="text-2xl font-bold mb-5"></h2>
    <div id="cart-items"></div>
    <div id="cart-subtotal"></div>
    <div id="cart-empty" class="text-center py-12 text-text-3"></div>
  </div>
</div>

<script is:inline define:vars={{ showCheckoutLink }}>
  function getLocale() { var m = window.location.pathname.match(/^\/(ne|newa)\//); return m ? m[1] : document.documentElement.dataset.locale || "en"; }
  var uiText = JSON.parse(document.getElementById("cart-widget")?.getAttribute("data-ui-text") || "{}");
  const CART_KEY = "metalhub-cart";

  function getCart() {
    try { return JSON.parse(localStorage.getItem(CART_KEY) || "[]"); } catch { return []; }
  }
  function saveCart(items) {
    localStorage.setItem(CART_KEY, JSON.stringify(items));
    window.dispatchEvent(new Event("cart-updated"));
  }

  function render() {
    const cart = getCart();
    const container = document.getElementById("cart-items");
    const subtotalEl = document.getElementById("cart-subtotal");
    const emptyEl = document.getElementById("cart-empty");
    const titleEl = document.getElementById("cart-title");
    if (!container || !subtotalEl || !emptyEl || !titleEl) return;

    titleEl.textContent = uiText.title;

    if (cart.length === 0) {
      container.innerHTML = "";
      subtotalEl.innerHTML = "";
      emptyEl.textContent = uiText.empty;
      emptyEl.classList.remove("hidden");
      return;
    }

    emptyEl.classList.add("hidden");
    let subtotal = 0;

    container.innerHTML = '<div class="space-y-4">' + cart.map((item, i) => {
      subtotal += item.unitPrice * item.qty;
      const options = Object.entries(item.selectedOptions || {}).map(([k,v]) => k + ": " + v).join(", ");
      var imgSrc = (item.images && item.images.length > 0 ? item.images[0] : "") || item.image || "";
      var imgHtml = imgSrc
        ? '<img src="' + imgSrc + '" alt="' + item.name + '" class="w-16 h-16 object-cover rounded-lg shrink-0" loading="lazy" decoding="async" />'
        : '<div class="w-16 h-16 rounded-lg bg-gradient-to-br from-surface-3 to-border shrink-0 flex items-center justify-center text-text-3 text-xs">' + uiText.noImg + '</div>';
      var loc = getLocale();
      var productHref = (loc === "en" ? "/products/" : "/" + loc + "/products/") + item.slug + "/" + (Object.keys(item.selectedOptions || {}).length > 0 ? "?" + new URLSearchParams(item.selectedOptions).toString() : "");
      return '<div class="flex items-center gap-4 p-4 bg-surface-2 border border-border rounded-xl">' +
        imgHtml +
        '<div class="flex-1 min-w-0">' +
          '<a href="' + productHref + '" class="text-base font-semibold mb-0.5 truncate block text-text-1 no-underline hover:text-accent transition-colors">' + item.name + '</a>' +
          (options ? '<p class="text-xs text-text-3 truncate">' + options + '</p>' : '') +
          '<p class="text-sm text-text-2 mt-1">NPR ' + item.unitPrice.toLocaleString() + ' \u00d7 ' + item.qty + ' = <span class="font-semibold text-accent-dark">NPR ' + (item.unitPrice * item.qty).toLocaleString() + '</span></p>' +
        '</div>' +
        '<div class="flex items-center gap-1.5 shrink-0">' +
          '<button onclick="window.__cartUpdateQty(' + i + ', ' + (item.qty - 1) + ')" class="w-7 h-7 flex items-center justify-center border border-border rounded-md bg-surface-2 cursor-pointer transition-colors hover:border-accent hover:text-accent text-sm">\u2212</button>' +
          '<span class="w-7 text-center text-sm font-bold">' + item.qty + '</span>' +
          '<button onclick="window.__cartUpdateQty(' + i + ', ' + (item.qty + 1) + ')" class="w-7 h-7 flex items-center justify-center border border-border rounded-md bg-surface-2 cursor-pointer transition-colors hover:border-accent hover:text-accent text-sm">+</button>' +
          '<button class="w-7 h-7 flex items-center justify-center border border-sale rounded-md bg-surface-2 text-sale cursor-pointer transition-colors hover:bg-sale hover:text-white text-sm ml-1" onclick="window.__cartRemoveItem(' + i + ')">\u00d7</button>' +
        '</div>' +
      '</div>';
    }).join("") + '</div>';

    const checkoutHref = getLocale() === "en" ? "/checkout/" : "/" + getLocale() + "/checkout/";
    const checkoutBtn = showCheckoutLink ? '<a href="' + checkoutHref + '" class="mt-4 inline-flex items-center justify-center w-full bg-success text-white border-none rounded-xl py-3 px-6 text-base font-semibold cursor-pointer no-underline transition-[colors,transform] hover:bg-green-800 hover:-translate-y-0.5">' + uiText.checkout + '</a>' : "";
    const clearAllBtn = '<button onclick="window.__cartClearAll()" class="mt-2 w-full inline-flex items-center justify-center bg-surface-2 border border-border text-text-2 rounded-xl py-2.5 px-6 text-sm font-semibold cursor-pointer transition-[colors,transform] hover:border-sale hover:text-sale hover:-translate-y-0.5">' + uiText.clearAll + '</button>';
    subtotalEl.innerHTML =
      '<div class="flex justify-between items-center text-xl font-extrabold py-5 border-t-2 border-border mt-2">' +
        '<span>' + uiText.subtotal + '</span>' +
        '<span>NPR ' + subtotal.toLocaleString() + '</span>' +
      '</div>' +
      clearAllBtn +
      checkoutBtn;
  }

  window.__cartUpdateQty = function(index, qty) {
    const cart = getCart();
    if (cart[index]) {
      cart[index].qty = Math.max(1, qty);
      saveCart(cart);
      render();
    }
  };

  window.__cartRemoveItem = function(index) {
    const cart = getCart();
    cart.splice(index, 1);
    saveCart(cart);
    render();
  };

  window.__cartClearAll = function() {
    saveCart([]);
    render();
  };

  document.addEventListener("astro:page-load", render);
  render();
</script>
