---
import OptimizedImage from "../components/OptimizedImage.astro";
import { getTranslations, type Locale, localizedPath } from "../lib/i18n";
import { formatPrice } from "../lib/pricing";

interface Props {
    slug: string;
    name: string;
    category: string;
    material?: string;
    categoryName?: string;
    materialName?: string;
    image: string;
    price: number;
    originalPrice: number;
    hasDiscount: boolean;
    discountLabel: string;
    inStock: boolean;
    stock: number;
    locale: Locale;
    variantParams?: string;
    attributeLabels?: Record<string, string>;
    saleType?: string;
    eventName?: string;
}

const {
    slug,
    name,
    category,
    material,
    categoryName,
    materialName,
    image,
    price,
    originalPrice,
    hasDiscount,
    discountLabel,
    inStock,
    stock,
    locale,
    variantParams,
    attributeLabels,
    saleType,
    eventName,
} = Astro.props;
const t = await getTranslations(locale);
const catLabel = categoryName || category;
const matLabel = materialName || material;
const productHref = localizedPath(variantParams ? `/products/${slug}/?${variantParams}` : `/products/${slug}/`, locale);
---
<a href={productHref} class="block bg-surface-2 border border-border rounded-xl overflow-hidden no-underline text-inherit transition-[colors,transform] duration-300 [perspective:800px] hover:-translate-y-1 hover:rotate-x-[1.5deg] hover:shadow-[0_20px_40px_-10px_rgb(15_23_42/0.15)]">
  <OptimizedImage src={image} alt={name} class="w-full h-48 md:h-64 object-contain bg-gradient-to-br from-surface-3 to-border" width={400} height={300} sizes="(min-width: 1024px) 33vw, (min-width: 768px) 50vw, 100vw" />
  <div class="p-4">
    <h2 class="text-base font-semibold mb-1 flex items-center flex-wrap gap-1.5">
      {name}
      {hasDiscount && <span class="inline-flex items-center bg-sale text-white text-[0.62rem] font-bold px-1.5 py-0.5 rounded uppercase tracking-wide">{saleType || t("products.sale")}</span>}
      {!inStock && <span class="inline-flex items-center bg-text-3 text-white text-[0.62rem] font-bold px-1.5 py-0.5 rounded uppercase">{t("products.outOfStock")}</span>}
    </h2>
    {attributeLabels && Object.keys(attributeLabels).length > 0 && (
      <p class="text-[0.62rem] text-text-3 mb-2">{Object.values(attributeLabels).join(" · ")}</p>
    )}
    <div class="flex items-center gap-1.5 flex-wrap mb-2">
      {matLabel && <span class="text-[0.62rem] font-bold px-1.5 py-0.5 rounded uppercase tracking-wide bg-surface-3 text-text-2">{matLabel}</span>}
      <span class="text-xs text-text-3">{catLabel}</span>
    </div>
    <div class="font-bold text-base text-accent-dark">
      {formatPrice(price)}
      {hasDiscount && <span class="line-through text-text-3 font-normal text-sm ml-1">{formatPrice(originalPrice)}</span>}
      {hasDiscount && <span class="inline-flex items-center bg-sale text-white text-[0.62rem] font-bold px-1.5 py-0.5 rounded uppercase tracking-wide ml-1">{discountLabel}</span>}
    </div>
    {stock > 0 ? (
      <p class="text-[0.62rem] text-success mt-0.5">{t("products.inStock").replace("{v}", String(stock))}</p>
    ) : (
      <p class="text-[0.62rem] text-sale mt-0.5">{t("products.outOfStock")}</p>
    )}
  </div>
</a>
