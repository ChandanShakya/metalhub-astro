---
import type { Locale } from "../lib/i18n";
import { getTranslations } from "../lib/i18n";

interface Props {
    locale: Locale;
    whatsappNumber: string;
    messengerPage: string;
}
const { locale, whatsappNumber, messengerPage } = Astro.props;
const t = getTranslations(locale);
---

<div id="order-error" class="hidden bg-red-50 border border-red-200 text-red-700 rounded-lg px-4 py-3 text-sm mb-4"></div>

<div class="flex flex-col gap-3 mt-6">
  <button id="btn-whatsapp" disabled class="bg-whatsapp text-white border-none rounded-xl py-3.5 px-5 text-base font-semibold cursor-not-allowed transition-[colors,transform] opacity-50 hover:bg-[#1eac5a] hover:-translate-y-px hover:shadow-[0_4px_12px_rgb(37_211_102/0.3)]">
    {t("checkout.orderWhatsApp")}
  </button>
  <button id="btn-messenger" disabled class="bg-messenger text-white border-none rounded-xl py-3.5 px-5 text-base font-semibold cursor-not-allowed transition-[colors,transform] opacity-50 hover:bg-[#005ce6] hover:-translate-y-px hover:shadow-[0_4px_12px_rgb(0_132_255/0.3)]">
    {t("checkout.orderMessenger")}
  </button>
</div>

<script is:inline define:vars={{ locale, whatsappNumber, messengerPage }}>
  var CART_KEY = "metalhub-cart";
  var errorMessages = {
    en: { nameRequired: "Please enter your name.", phoneRequired: "Please enter your phone number.", phoneInvalid: "Please enter a valid 10-digit phone number.", locationRequired: "Please select a delivery location on the map.", cartEmpty: "Your cart is empty." },
    ne: { nameRequired: "कृपया आफ्नो नाम लेख्नुहोस्।", phoneRequired: "कृपया फोन नम्बर लेख्नुहोस्।", phoneInvalid: "कृपया मान्य १० अंकको फोन नम्बर लेख्नुहोस्।", locationRequired: "कृपया नक्सामा डेलिभरी स्थान छान्नुहोस्।", cartEmpty: "तपाईंको कार्ट खाली छ।" },
    newa: { nameRequired: "खास नां लेखु।", phoneRequired: "खास फोन नम्बर लेखु।", phoneInvalid: "खास मान्य १० अंक फोन नम्बर लेखु।", locationRequired: "खास नक्सा यायं डेलिभरी स्थान छिनु।", cartEmpty: "छिग्व म्हिग्व असः खाली।" }
  };
  var em = errorMessages[locale] || errorMessages.en;

  function getCart() {
    try { return JSON.parse(localStorage.getItem(CART_KEY) || "[]"); } catch { return []; }
  }

  function showError(msg) {
    var el = document.getElementById("order-error");
    if (el) { el.textContent = msg; el.classList.remove("hidden"); }
  }

  function clearError() {
    var el = document.getElementById("order-error");
    if (el) el.classList.add("hidden");
  }

  function checkFormValid() {
    var name = (document.getElementById("customer-name")?.value || "").trim();
    var phone = (document.getElementById("customer-phone")?.value || "").trim();
    var lat = document.getElementById("delivery-lat")?.value;
    var lng = document.getElementById("delivery-lng")?.value;
    var cart = getCart();
    return cart.length > 0 && name.length >= 2 && /^\d{10}$/.test(phone) && lat && lng;
  }

  function updateButtonState() {
    var valid = checkFormValid();
    var whatsappBtn = document.getElementById("btn-whatsapp");
    var messengerBtn = document.getElementById("btn-messenger");
    if (whatsappBtn) {
      whatsappBtn.disabled = !valid;
      whatsappBtn.classList.toggle("opacity-50", !valid);
      whatsappBtn.classList.toggle("cursor-not-allowed", !valid);
      whatsappBtn.classList.toggle("cursor-pointer", valid);
    }
    if (messengerBtn) {
      messengerBtn.disabled = !valid;
      messengerBtn.classList.toggle("opacity-50", !valid);
      messengerBtn.classList.toggle("cursor-not-allowed", !valid);
      messengerBtn.classList.toggle("cursor-pointer", valid);
    }
  }

  function validate() {
    clearError();
    var cart = getCart();
    if (cart.length === 0) { showError(em.cartEmpty); return false; }

    var name = (document.getElementById("customer-name")?.value || "").trim();
    if (!name || name.length < 2) { showError(em.nameRequired); document.getElementById("customer-name")?.focus(); return false; }

    var phone = (document.getElementById("customer-phone")?.value || "").trim();
    if (!phone) { showError(em.phoneRequired); document.getElementById("customer-phone")?.focus(); return false; }
    if (!/^\d{10}$/.test(phone)) { showError(em.phoneInvalid); document.getElementById("customer-phone")?.focus(); return false; }

    var lat = document.getElementById("delivery-lat")?.value;
    var lng = document.getElementById("delivery-lng")?.value;
    if (!lat || !lng) { showError(em.locationRequired); return false; }

    return true;
  }

  function buildMessage(name, phone, note) {
    var cart = getCart();
    var msg = "New Order \u2014 Metal Hub\n\n";
    msg += "Customer: " + name + "\n";
    msg += "Phone: " + phone + "\n\n";
    msg += "Items:\n";

    cart.forEach(function(item, i) {
      var opts = Object.entries(item.selectedOptions || {}).map(function(e) { return e[0] + ": " + e[1]; }).join(", ");
      var price = item.hasDiscount
        ? "NPR " + item.unitPrice.toLocaleString() + " (was NPR " + item.originalUnitPrice.toLocaleString() + ")"
        : "NPR " + item.unitPrice.toLocaleString();
      msg += (i + 1) + ". " + item.name + (opts ? " (" + opts + ")" : "") + " x" + item.qty + " \u2014 " + price + "\n";

      var params = new URLSearchParams();
      Object.entries(item.selectedOptions || {}).forEach(function(e) { params.set(e[0], e[1]); });
      var productPath = locale === "en" ? "/products/" + item.slug + "/" : "/" + locale + "/products/" + item.slug + "/";
      var productUrl = window.location.origin + productPath + (params.toString() ? "?" + params.toString() : "");
      msg += "   " + productUrl + "\n";
    });

    var subtotal = cart.reduce(function(s, item) { return s + item.unitPrice * item.qty; }, 0);
    msg += "\nSubtotal: NPR " + subtotal.toLocaleString() + "\n";

    var lat = document.getElementById("delivery-lat")?.value;
    var lng = document.getElementById("delivery-lng")?.value;
    if (lat && lng) {
      msg += "\nDelivery location: https://www.google.com/maps?q=" + lat + "," + lng + "\n";
    }

    if (note) msg += "\nNote: " + note + "\n";
    msg += "\nPlease confirm availability, delivery time, and how you'd like me to pay. Thank you!";

    return msg;
  }

  function openWhatsApp() {
    if (!validate()) return;
    var name = document.getElementById("customer-name").value.trim();
    var phone = document.getElementById("customer-phone").value.trim();
    var note = (document.getElementById("customer-note")?.value || "").trim();
    var msg = buildMessage(name, phone, note);
    window.open("https://wa.me/" + whatsappNumber + "?text=" + encodeURIComponent(msg), "_blank");
  }

  function openMessenger() {
    if (!validate()) return;
    var name = document.getElementById("customer-name").value.trim();
    var phone = document.getElementById("customer-phone").value.trim();
    var note = (document.getElementById("customer-note")?.value || "").trim();
    var msg = buildMessage(name, phone, note);
    window.open("https://m.me/" + messengerPage + "?text=" + encodeURIComponent(msg), "_blank");
  }

  var _orderAbort = null;

  document.addEventListener("astro:page-load", function() {
    if (_orderAbort) _orderAbort.abort();
    _orderAbort = new AbortController();
    var signal = _orderAbort.signal;

    var whatsappBtn = document.getElementById("btn-whatsapp");
    var messengerBtn = document.getElementById("btn-messenger");
    if (whatsappBtn) whatsappBtn.onclick = openWhatsApp;
    if (messengerBtn) messengerBtn.onclick = openMessenger;

    var nameEl = document.getElementById("customer-name");
    var phoneEl = document.getElementById("customer-phone");
    if (nameEl) nameEl.addEventListener("input", updateButtonState, { signal: signal });
    if (phoneEl) phoneEl.addEventListener("input", updateButtonState, { signal: signal });
    window.addEventListener("checkout-field-changed", updateButtonState, { signal: signal });

    updateButtonState();
  });
</script>
