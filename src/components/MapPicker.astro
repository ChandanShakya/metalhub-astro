---
import type { Locale } from "../lib/i18n";
import { getTranslations } from "../lib/i18n";

// CSS is lazy-loaded alongside JS via dynamic import() in loadMap().

interface Props {
    locale: Locale;
}
const { locale } = Astro.props;
const t = await getTranslations(locale);
---

<div class="mb-4">
  <label for="map" class="block font-semibold text-sm mb-2 text-text-1">{t("checkout.deliveryPoint")}</label>
  <div id="map" data-ui-text={JSON.stringify({ pinSet: t("checkout.pinSet"), loadErr: t("checkout.mapLoadErr"), searchPlaceholder: t("checkout.searchPlaceholder"), gpsLocate: t("checkout.gpsLocate"), locating: t("checkout.locating"), gpsError: t("checkout.gpsError"), gpsDenied: t("checkout.gpsDenied"), gpsUnsupported: t("checkout.gpsUnsupported") })} class="w-full h-105 border border-border rounded-xl mb-2 relative isolate"></div>
  <div id="map-status" aria-live="polite" class="text-sm min-h-5 font-medium"></div>
</div>

<input type="hidden" id="delivery-lat" />
<input type="hidden" id="delivery-lng" />

<script>
  import type * as leaflet from "leaflet";

  var STORAGE_KEY = "metalhub-customer";

  function loadCustomer() {
    try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || "{}"); } catch { return {}; }
  }

  function getUiText() {
    try { return JSON.parse(document.getElementById("map")?.getAttribute("data-ui-text") || "{}"); } catch { return {}; }
  }

  window.__mapCtx = window.__mapCtx || { id: 0, abort: null };
  var _mapId = ++window.__mapCtx.id;

  document.addEventListener("astro:page-load", function() {
    if (window.__mapCtx.id !== _mapId) return;
    if (window.__mapCtx.abort) window.__mapCtx.abort.abort();
    window.__mapCtx.abort = new AbortController();
    var signal = window.__mapCtx.abort.signal;

    var mapEl = document.getElementById("map");
    var statusEl = document.getElementById("map-status");
    if (!mapEl || mapEl.dataset.initialized) return;

    var uiText = getUiText();

    var observer = new IntersectionObserver(function(entries) {
      if (entries[0].isIntersecting) {
        observer.disconnect();
        mapEl!.dataset.initialized = "true";
        loadMap(mapEl!, statusEl!, uiText);
      }
    }, { rootMargin: "200px" });
    observer.observe(mapEl);

    signal.addEventListener("abort", function() { observer.disconnect(); }, { once: true });
  });

  async function loadMap(mapEl: HTMLElement, statusEl: HTMLElement, uiText: Record<string, string>) {
    try {
      await import("leaflet/dist/leaflet.css");
      await import("leaflet-control-geocoder/dist/Control.Geocoder.css");
      var leafletModule = await import("leaflet");
      await import("leaflet-control-geocoder");
      var L = leafletModule.default || leafletModule;
      // Set marker icon URLs using Vite-processed imports so images resolve
      // correctly on Cloudflare (dynamic import breaks Leaflet's auto-detection).
      // Vite dev returns {src,width,height,format}, Vite build returns the URL string directly.
      var iconDef = await import("leaflet/dist/images/marker-icon.png");
      var retinaDef = await import("leaflet/dist/images/marker-icon-2x.png");
      var shadowDef = await import("leaflet/dist/images/marker-shadow.png");
      var imgUrl = function(m: { default: string | { src: string } }) { return typeof m.default === "string" ? m.default : m.default.src; };
      L.Icon.Default.mergeOptions({
        iconUrl: imgUrl(iconDef),
        iconRetinaUrl: imgUrl(retinaDef),
        shadowUrl: imgUrl(shadowDef),
      });
      window.L = L;
      initMap(mapEl, statusEl, uiText, L);
    } catch (e) {
      statusEl.textContent = uiText.loadErr;
      statusEl.classList.add("text-sale");
    }
  }

  function initMap(mapEl: HTMLElement, statusEl: HTMLElement, uiText: Record<string, string>, L: typeof import("leaflet")) {
    var saved = loadCustomer();
    var hasSaved = saved.lat && saved.lng;
    var center: [number, number] = hasSaved ? [parseFloat(saved.lat), parseFloat(saved.lng)] : [27.7172, 85.3240];
    var zoom = hasSaved ? 14 : 12;
    var map = L.map(mapEl).setView(center, zoom);

    requestAnimationFrame(function() { map.invalidateSize(); });

    L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
      attribution: "\u00a9 <a href=\"https://www.openstreetmap.org/copyright\">OpenStreetMap</a>"
    }).addTo(map);

    var LControl = L.Control as any;
    var geocoder = LControl.Geocoder.nominatim({
      geocodingQueryParams: { countrycodes: "np" }
    });
    var geocoderControl = new LControl.Geocoder({
      geocoder: geocoder,
      position: "topright",
      placeholder: uiText.searchPlaceholder,
      defaultMarkGeocode: false,
      formatGeocode: function(result: { name?: string }) {
        return result.name || "";
      }
    }).addTo(map);

    geocoderControl.on("markgeocode", function(e: { geocode: { center: leaflet.LatLng } }) {
      if (e.geocode && e.geocode.center) {
        setMarker(e.geocode.center);
        map.setView(e.geocode.center, 16);
      }
    });

    var LocateControl = L.Control.extend({
      options: { position: "topleft" },
      onAdd: function() {
        var container = L.DomUtil.create("div", "leaflet-bar leaflet-control");
        container.innerHTML = '<button class="gps-btn" style="width:34px;height:34px;cursor:pointer;display:flex;align-items:center;justify-content:center;border:none;background:#fff;border-radius:2px;" title="' + uiText.gpsLocate + '"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#333" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="2"/><path d="M12 2v4M12 18v4M2 12h4M18 12h4"/></svg></button>';
        L.DomEvent.disableClickPropagation(container);
        L.DomEvent.on(container, "click", function() {
          if (!navigator.geolocation) {
            statusEl.textContent = uiText.gpsUnsupported;
            statusEl.classList.add("text-sale");
            statusEl.classList.remove("text-success");
            return;
          }
          statusEl.textContent = uiText.locating;
          statusEl.classList.remove("text-sale", "text-success");
          navigator.geolocation.getCurrentPosition(function(pos) {
            setMarker(L.latLng(pos.coords.latitude, pos.coords.longitude));
            map.setView(L.latLng(pos.coords.latitude, pos.coords.longitude), 16);
          }, function(err) {
            statusEl.textContent = err.code === 1 ? uiText.gpsDenied : uiText.gpsError;
            statusEl.classList.add("text-sale");
            statusEl.classList.remove("text-success");
          }, { enableHighAccuracy: true, timeout: 10000 });
        });
        return container;
      }
    });
    map.addControl(new LocateControl());

    var marker: leaflet.Marker | null = null;

    function setMarker(latlng: leaflet.LatLng) {
      if (marker) map.removeLayer(marker);
      marker = L.marker(latlng).addTo(map);

      var input = document.getElementById("delivery-lat") as HTMLInputElement | null;
      var inputLng = document.getElementById("delivery-lng") as HTMLInputElement | null;
      if (input) input.value = String(latlng.lat);
      if (inputLng) inputLng.value = String(latlng.lng);

      if (typeof window.__saveCustomerLocation === "function") {
        window.__saveCustomerLocation();
      }

      statusEl.textContent = uiText.pinSet;
      statusEl.classList.add("text-success");
      statusEl.classList.remove("text-sale");
    }

    if (hasSaved) setMarker(L.latLng(center[0], center[1]));
    map.on("click", function(e: leaflet.LeafletMouseEvent) { setMarker(e.latlng); });
  }
</script>
