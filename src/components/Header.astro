---
import { getTranslations, type Locale, localizedPath } from "../lib/i18n";

interface Props {
    locale: Locale;
    currentPath: string;
}

const { locale, currentPath } = Astro.props;
const t = getTranslations(locale);

const navItems = [
    { href: "/", key: "nav.home" },
    { href: "/products/", key: "nav.products" },
    { href: "/social/", key: "nav.social" },
];

const langLabels: Record<string, string> = { en: "EN", ne: "नेपाली", newa: "नेवाः" };

const checkoutPath = locale === "en" ? "/checkout/" : `/${locale}/checkout/`;
const isCheckout = currentPath.includes("/checkout");

function langHref(langCode: string) {
    let path = currentPath;
    if (locale !== "en") {
        path = path.replace(new RegExp(`^/${locale}/?`), "/");
    }
    if (langCode === "en") return path;
    return path === "/" ? `/${langCode}/` : `/${langCode}${path}`;
}

const langs = ["en", "ne", "newa"] as const;
---

<header class="sticky top-0 z-50 bg-white/90 backdrop-blur-xl border-b border-border">
  <div class="mx-auto max-w-site flex items-center justify-between px-4 py-3 md:px-6 md:py-3.5">
    <a href={localizedPath("/", locale)} class="flex items-center gap-2 text-lg font-bold text-text-1 no-underline hover:no-underline" aria-label="Metal Hub Home">
      <span class="inline-flex items-center justify-center w-7 h-7 bg-accent text-white text-[0.65rem] font-extrabold rounded-lg">MH</span>
      Metal Hub
    </a>

    <nav class="flex items-center gap-3 md:gap-6" aria-label="Main navigation">
      {navItems.map((item) => {
        const href = localizedPath(item.href, locale);
        const isActive = item.href === "/" ? currentPath === "/" || currentPath === `/${locale}/` : currentPath.startsWith(href);
        return (
          <a
            href={href}
            class:list={[
                "hidden md:inline text-sm font-medium no-underline transition-colors py-1 border-b-2",
                isActive ? "text-accent border-accent" : "text-text-2 border-transparent hover:text-accent"
            ]}
          >
            {t(item.key)}
          </a>
        );
      })}
      <div class="relative cart-dropdown-wrapper">
        <a href={checkoutPath} class:list={["relative flex items-center no-underline cart-link", isCheckout ? "text-accent" : "text-text-2"]} aria-label={t("nav.checkout")}>
          <svg class:list={["transition-colors", isCheckout ? "stroke-accent" : "stroke-text-2 hover:stroke-accent"]} width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
            <path d="m1 1 4 0 2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
          </svg>
          <span id="cart-badge" class="absolute -top-1.5 -right-2 hidden bg-sale text-white text-[0.6rem] font-bold min-w-4 h-4 rounded-full items-center justify-center px-1 leading-none" aria-label="items in cart">0</span>
        </a>
        <div id="cart-dropdown" data-ui-text={JSON.stringify({ empty: t("cart.empty"), subtotal: t("cart.subtotal"), checkout: t("cart.checkout"), noImg: t("cart.noImg") })} class="hidden fixed md:absolute top-full right-0 mt-2 w-80 max-w-[calc(100vw-2rem)] bg-surface-2 border border-border rounded-xl shadow-xl z-200 overflow-hidden">
          <div class="p-4">
            <div id="cart-dropdown-items"></div>
            <div id="cart-empty" class="text-center py-4 text-text-3 text-sm"></div>
            <div id="cart-dropdown-footer"></div>
          </div>
        </div>
      </div>
      <div class="relative hidden md:block ml-2 pl-2 border-l border-border">
        <label for="lang-select-desktop" class="sr-only">Language</label>
        <select id="lang-select-desktop" class="lang-select bg-surface-2 border border-border rounded-lg px-2 py-1 text-sm font-medium text-text-2 cursor-pointer hover:border-accent hover:text-accent transition-[colors,transform] appearance-none pr-6 bg-[url('data:image/svg+xml;charset=utf-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%2210%22%20height%3D%226%22%20fill%3D%22none%22%3E%3Cpath%20d%3D%22M1%201l4%204%204-4%22%20stroke%3D%22%23475569%22%20stroke-width%3D%221.5%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%2F%3E%3C%2Fsvg%3E')] bg-[length:10px_6px] bg-[right_6px_center] bg-no-repeat">
          {langs.map((lang) => (
            <option value={langHref(lang)} selected={locale === lang}>{langLabels[lang]}</option>
          ))}
        </select>
      </div>

      <button id="mobile-menu-btn" class="md:hidden flex items-center justify-center w-9 h-9 -mr-1 rounded-lg text-text-2 hover:text-accent hover:bg-surface-2 transition-colors cursor-pointer" aria-label="Open menu" aria-expanded="false">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </nav>
  </div>
</header>

<div id="mobile-drawer-backdrop" class="hidden fixed inset-0 z-300 md:hidden" style="background:rgba(0,0,0,0.4)"></div>
<div id="mobile-drawer" class="hidden fixed top-0 right-0 h-full w-72 max-w-[85vw] z-301 shadow-2xl flex flex-col md:hidden translate-x-full transition-transform duration-200" style="background-color:#fff">
  <div class="flex items-center justify-between px-4 py-3 border-b border-border">
    <a href={localizedPath("/", locale)} class="flex items-center gap-2 text-base font-bold text-text-1 no-underline hover:no-underline" aria-label="Metal Hub Home">
      <span class="inline-flex items-center justify-center w-6 h-6 bg-accent text-white text-[0.6rem] font-extrabold rounded-lg">MH</span>
      Metal Hub
    </a>
    <button id="mobile-drawer-close" class="flex items-center justify-center w-8 h-8 rounded-lg text-text-2 hover:text-accent hover:bg-surface-2 transition-colors cursor-pointer" aria-label="Close menu">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>
  <div class="flex-1 overflow-y-auto">
    {navItems.map((item) => {
      const href = localizedPath(item.href, locale);
      const label = t(item.key);

      const isActive = item.href === "/" ? currentPath === "/" || currentPath === `/${locale}/` : currentPath.startsWith(href);
      return (
        <a
          href={href}
          aria-label={label}
          title={label}
          class:list={[
              "mobile-drawer-link block px-5 py-3.5 text-sm font-medium no-underline transition-colors border-b",
              isActive ? "text-accent border-border" : "text-text-2 border-border hover:text-accent hover:bg-surface-2"
          ]}
        >
          {t(item.key)}
        </a>
      );
    })}
  </div>
  <div class="border-t border-border px-4 py-4">
    <label for="lang-select-mobile" class="sr-only">Language</label>
    <select id="lang-select-mobile" class="lang-select w-full bg-surface-2 border border-border rounded-lg px-3 py-2 text-sm font-medium text-text-2 cursor-pointer hover:border-accent hover:text-accent transition-[colors,transform] appearance-none pr-8 bg-[url('data:image/svg+xml;charset=utf-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%2210%22%20height%3D%226%22%20fill%3D%22none%22%3E%3Cpath%20d%3D%22M1%201l4%204%204-4%22%20stroke%3D%22%23475569%22%20stroke-width%3D%221.5%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%2F%3E%3C%2Fsvg%3E')] bg-[length:10px_6px] bg-[right_10px_center] bg-no-repeat">
      {langs.map((lang) => (
        <option value={langHref(lang)} selected={locale === lang}>{langLabels[lang]}</option>
      ))}
    </select>
  </div>
</div>

<script is:inline define:vars={{ langLabels: JSON.stringify(langLabels) }}>
  function getLocale() { var m = window.location.pathname.match(/^\/(ne|newa)\//); return m ? m[1] : document.documentElement.dataset.locale || "en"; }
  var CART_KEY = "metalhub-cart";
  var uiText = JSON.parse(document.getElementById("cart-dropdown")?.getAttribute("data-ui-text") || "{}");

  function getCart() {
    try { return JSON.parse(localStorage.getItem(CART_KEY) || "[]"); } catch { return []; }
  }
  function saveCart(items) {
    localStorage.setItem(CART_KEY, JSON.stringify(items));
    window.dispatchEvent(new Event("cart-updated"));
  }

  function updateCartBadge() {
    try {
      var cart = getCart();
      var count = cart.reduce(function(s, i) { return s + i.qty; }, 0);
      var badge = document.getElementById("cart-badge");
      if (badge) {
        if (count > 0) {
          badge.classList.remove("hidden");
          badge.classList.add("inline-flex");
          badge.textContent = String(count);
          badge.setAttribute("aria-label", count + " items in cart");
        } else {
          badge.classList.add("hidden");
          badge.classList.remove("inline-flex");
        }
      }
    } catch {}
  }

  function renderCartDropdown() {
    var cart = getCart();
    var itemsEl = document.getElementById("cart-dropdown-items");
    var emptyEl = document.getElementById("cart-empty");
    var footerEl = document.getElementById("cart-dropdown-footer");
    if (!itemsEl || !emptyEl || !footerEl) return;

    if (cart.length === 0) {
      itemsEl.innerHTML = "";
      emptyEl.textContent = uiText.empty;
      emptyEl.classList.remove("hidden");
      footerEl.innerHTML = "";
      return;
    }

    emptyEl.classList.add("hidden");
    var subtotal = 0;
    itemsEl.innerHTML = cart.map(function(item, i) {
      subtotal += item.unitPrice * item.qty;
      var opts = Object.entries(item.selectedOptions || {}).map(function(e) { return e[0] + ": " + e[1]; }).join(", ");
      var params = new URLSearchParams();
      Object.entries(item.selectedOptions || {}).forEach(function(e) { params.set(e[0], e[1]); });
      var queryStr = params.toString() ? "?" + params.toString() : "";
      var loc = getLocale();
      var productHref = (loc === "en" ? "/products/" : "/" + loc + "/products/") + item.slug + "/" + queryStr;
      var imgSrc = (item.images && item.images.length > 0 ? item.images[0] : "") || item.image || "";
      var imgHtml = imgSrc
        ? '<img src="' + imgSrc + '" alt="' + item.name + '" class="w-10 h-10 object-cover rounded-lg shrink-0" loading="lazy" decoding="async" />'
        : '<div class="w-10 h-10 rounded-lg bg-gradient-to-br from-surface-3 to-border shrink-0 flex items-center justify-center text-text-3 text-xs">' + uiText.noImg + '</div>';
      return '<div class="flex items-center gap-3 py-2 border-b border-border last:border-0">' +
        imgHtml +
        '<div class="flex-1 min-w-0">' +
          '<a href="' + productHref + '" class="text-sm font-semibold truncate text-text-1 no-underline hover:text-accent transition-colors block">' + item.name + '</a>' +
          (opts ? '<p class="text-xs text-text-3 truncate">' + opts + '</p>' : '') +
          '<p class="text-xs text-text-2">NPR ' + item.unitPrice.toLocaleString() + ' \u00d7 ' + item.qty + '</p>' +
        '</div>' +
        '<div class="flex items-center gap-1">' +
          '<button onclick="window.__cartUpdateQty(' + i + ',' + (item.qty - 1) + ')" class="w-6 h-6 flex items-center justify-center border border-border rounded text-xs cursor-pointer hover:border-accent hover:text-accent transition-colors">\u2212</button>' +
          '<span class="w-6 text-center text-sm font-bold">' + item.qty + '</span>' +
          '<button onclick="window.__cartUpdateQty(' + i + ',' + (item.qty + 1) + ')" class="w-6 h-6 flex items-center justify-center border border-border rounded text-xs cursor-pointer hover:border-accent hover:text-accent transition-colors">+</button>' +
          '<button onclick="window.__cartRemoveItem(' + i + ')" class="w-6 h-6 flex items-center justify-center border border-sale rounded text-xs text-sale cursor-pointer hover:bg-sale hover:text-white transition-colors ml-1">\u00d7</button>' +
        '</div>' +
      '</div>';
    }).join("");

    var checkoutHref = getLocale() === "en" ? "/checkout/" : "/" + getLocale() + "/checkout/";
    footerEl.innerHTML =
      '<div class="flex justify-between items-center font-bold text-sm pt-2 mt-1 border-t border-border">' +
        '<span>' + uiText.subtotal + '</span>' +
        '<span>NPR ' + subtotal.toLocaleString() + '</span>' +
      '</div>' +
      '<a href="' + checkoutHref + '" class="mt-3 block text-center bg-success text-white rounded-lg py-2 text-sm font-semibold no-underline hover:bg-green-800 transition-colors">' + uiText.checkout + '</a>';
  }

  window.__cartUpdateQty = function(index, qty) {
    var cart = getCart();
    if (cart[index]) {
      cart[index].qty = Math.max(1, qty);
      saveCart(cart);
      renderCartDropdown();
      updateCartBadge();
    }
  };

  window.__cartRemoveItem = function(index) {
    var cart = getCart();
    cart.splice(index, 1);
    saveCart(cart);
    renderCartDropdown();
    updateCartBadge();
  };

  function positionCartDropdown(dropdown, wrapper) {
    var isMobile = window.innerWidth < 768;
    if (isMobile) {
      var rect = wrapper.getBoundingClientRect();
      dropdown.style.position = "fixed";
      dropdown.style.top = (rect.bottom + 8) + "px";
      dropdown.style.right = (window.innerWidth - rect.right) + "px";
      dropdown.style.left = "auto";
      dropdown.style.transform = "none";
    } else {
      dropdown.style.position = "";
      dropdown.style.top = "";
      dropdown.style.right = "";
      dropdown.style.left = "";
      dropdown.style.transform = "";
    }
  }

  window.__headerCtx = window.__headerCtx || { id: 0, abort: null };
  var _headerId = ++window.__headerCtx.id;

  document.addEventListener("change", function(e) {
    if (e.target.classList.contains("lang-select")) {
      var a = document.createElement("a");
      a.href = e.target.value;
      document.body.appendChild(a);
      a.click();
      a.remove();
    }
  });

  document.addEventListener("astro:page-load", function() {
    if (window.__headerCtx.id !== _headerId) return;
    if (window.__headerCtx.abort) window.__headerCtx.abort.abort();
    window.__headerCtx.abort = new AbortController();
    var signal = window.__headerCtx.abort.signal;

    updateCartBadge();
    renderCartDropdown();

    var wrapper = document.querySelector(".cart-dropdown-wrapper");
    var dropdown = document.getElementById("cart-dropdown");
    if (wrapper && dropdown) {
      var link = wrapper.querySelector(".cart-link");
      link.addEventListener("click", function(e) {
        e.preventDefault();
        e.stopPropagation();
        var isHidden = dropdown.classList.contains("hidden");
        dropdown.classList.toggle("hidden");
        if (isHidden) {
          positionCartDropdown(dropdown, wrapper);
          renderCartDropdown();
        }
      }, { signal: signal });

      document.addEventListener("click", function(e) {
        if (!dropdown.contains(e.target) && !wrapper.contains(e.target)) {
          dropdown.classList.add("hidden");
        }
      }, { signal: signal });
    }

    var menuBtn = document.getElementById("mobile-menu-btn");
    var drawer = document.getElementById("mobile-drawer");
    var backdrop = document.getElementById("mobile-drawer-backdrop");
    var closeBtn = document.getElementById("mobile-drawer-close");

    function openDrawer() {
      drawer.classList.remove("hidden");
      backdrop.classList.remove("hidden");
      requestAnimationFrame(function() {
        drawer.classList.remove("translate-x-full");
        drawer.classList.add("translate-x-0");
      });
      menuBtn.setAttribute("aria-expanded", "true");
      document.body.style.overflow = "hidden";
    }

    function closeDrawer() {
      drawer.classList.remove("translate-x-0");
      drawer.classList.add("translate-x-full");
      backdrop.classList.add("hidden");
      menuBtn.setAttribute("aria-expanded", "false");
      document.body.style.overflow = "";
      setTimeout(function() { drawer.classList.add("hidden"); }, 200);
    }

    if (menuBtn && drawer && backdrop) {
      menuBtn.addEventListener("click", function(e) {
        e.stopPropagation();
        var expanded = menuBtn.getAttribute("aria-expanded") === "true";
        if (expanded) closeDrawer(); else openDrawer();
      }, { signal: signal });

      backdrop.addEventListener("click", closeDrawer, { signal: signal });
      if (closeBtn) closeBtn.addEventListener("click", closeDrawer, { signal: signal });

      drawer.querySelectorAll(".mobile-drawer-link").forEach(function(link) {
        link.addEventListener("click", closeDrawer, { signal: signal });
      });
    }
  });
  window.addEventListener("storage", updateCartBadge);
  window.addEventListener("cart-updated", function() {
    updateCartBadge();
    renderCartDropdown();
  });
</script>
