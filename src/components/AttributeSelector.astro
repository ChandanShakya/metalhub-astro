---
import type { Locale } from "../lib/i18n";
import { getTranslations } from "../lib/i18n";

interface LocalizedString {
    en: string;
    ne: string;
    newa: string;
}
interface AttributeOption {
    label: LocalizedString;
    priceModifier?: number;
    discount?: { active?: boolean; type?: string; value?: number };
    images?: string[];
}
interface Props {
    attributes: { name: LocalizedString; options: AttributeOption[] }[];
    locale: Locale;
    basePrice: number;
    productSlug: string;
    productName: string;
    productNameAll: LocalizedString;
    productImage?: string;
}
const { attributes, locale, basePrice, productSlug, productName, productNameAll, productImage } = Astro.props;
const t = getTranslations(locale);
const checkoutPath = locale === "en" ? "/checkout/" : `/${locale}/checkout/`;

function localize(obj: LocalizedString): string {
    return obj[locale] || obj.en;
}
---

<div id="product-attributes">
  {attributes.map((attr) => (
    <fieldset class="mb-4 border-none p-0 m-0">
      <legend class="block font-semibold text-sm mb-2 text-text-1 p-0">{localize(attr.name)}</legend>
      <div class="flex gap-2 flex-wrap" data-attribute-name={localize(attr.name)} data-key={attr.name.en}>
        {attr.options.map((opt: AttributeOption) => (
          <button
            class="attr-option px-3.5 py-2 bg-surface-2 border-2 border-border rounded-lg cursor-pointer text-sm font-medium transition-[colors,transform] text-text-1 hover:border-accent-light"
            data-label={localize(opt.label)}
            data-key={opt.label.en}
            data-modifier={opt.priceModifier || 0}
            data-discount-active={opt.discount?.active || false}
            data-discount-type={opt.discount?.type || "percentage"}
            data-discount-value={opt.discount?.value || 0}
            data-images={opt.images ? JSON.stringify(opt.images) : "[]"}
            data-selected="false"
          >
            {localize(opt.label)}
            {opt.discount?.active && <span class="inline-flex items-center bg-sale text-white text-[0.62rem] font-bold px-1.5 py-0.5 rounded uppercase ml-1">{t("products.sale")}</span>}
          </button>
        ))}
      </div>
    </fieldset>
  ))}
</div>

<div id="price-display" class="text-2xl font-extrabold my-4 text-text-1"></div>

<div class="flex items-center gap-3 mb-2">
  <label for="qty-input" class="text-sm font-medium text-text-2">{t("products.qty")}</label>
  <div class="flex items-center border-2 border-border rounded-lg overflow-hidden">
    <button id="qty-minus" aria-label="Decrease quantity" class="w-9 h-9 flex items-center justify-center bg-surface-2 cursor-pointer transition-colors hover:bg-surface-3 text-text-1 font-bold border-none">-</button>
    <input id="qty-input" type="number" min="1" max="99" value="1" class="w-12 h-9 text-center border-none bg-surface-2 text-text-1 font-semibold text-base [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none" />
    <button id="qty-plus" aria-label="Increase quantity" class="w-9 h-9 flex items-center justify-center bg-surface-2 cursor-pointer transition-colors hover:bg-surface-3 text-text-1 font-bold border-none">+</button>
  </div>
</div>

<div class="flex flex-col gap-2 mt-2">
  <button
    id="add-to-cart-btn"
    class="bg-accent text-white border-none rounded-xl py-3 px-6 text-base font-semibold cursor-pointer transition-[colors,transform] opacity-50 cursor-not-allowed"
    data-base-price={basePrice}
    data-product-slug={productSlug}
    data-product-name={productName}
    data-product-name-all={JSON.stringify(productNameAll)}
    data-product-image={productImage}
    data-ui-text={JSON.stringify({ added: t("products.added"), addToCart: t("products.addToCart"), percentOff: t("products.percentOff"), amountOff: t("products.amountOff") })}
    disabled
  >
    {t("products.addToCart")}
  </button>
  <a id="go-checkout-btn" href={checkoutPath} class="hidden items-center justify-center bg-success text-white border-none rounded-xl py-3 px-6 text-base font-semibold cursor-pointer no-underline transition-[colors,transform] hover:bg-green-800 hover:-translate-y-px">
    {t("products.goToCheckout")}
  </a>
</div>

<script is:inline define:vars={{ checkoutPath }}>
  var CART_KEY = "metalhub-cart";
  var uiText = JSON.parse(document.getElementById("add-to-cart-btn")?.getAttribute("data-ui-text") || "{}");

  function getCart() {
    try { return JSON.parse(localStorage.getItem(CART_KEY) || "[]"); } catch { return []; }
  }
  function saveCart(items) {
    localStorage.setItem(CART_KEY, JSON.stringify(items));
    window.dispatchEvent(new Event("cart-updated"));
  }

  function selectOption(btn) {
    var group = btn.closest("[data-attribute-name]");
    if (!group) return;
    group.querySelectorAll(".attr-option").forEach(function(b) {
      b.setAttribute("data-selected", "false");
      b.classList.remove("border-accent", "bg-accent-surface", "text-accent-dark", "font-semibold");
      b.classList.add("border-border", "bg-surface-2", "text-text-1");
    });
    btn.setAttribute("data-selected", "true");
    btn.classList.remove("border-border", "bg-surface-2", "text-text-1");
    btn.classList.add("border-accent", "bg-accent-surface", "text-accent-dark", "font-semibold");

    var imagesStr = btn.getAttribute("data-images") || "[]";
    var images = [];
    try { images = JSON.parse(imagesStr); } catch(e) {}
    if (images.length > 0) {
      window.dispatchEvent(new CustomEvent("attribute-image-changed", { detail: { images: images } }));
    }
  }

  function areAllGroupsSelected() {
    var groups = document.querySelectorAll("[data-attribute-name]");
    for (var i = 0; i < groups.length; i++) {
      if (!groups[i].querySelector('[data-selected="true"]')) return false;
    }
    return groups.length > 0;
  }

  function updateAddToCartState() {
    var btn = document.getElementById("add-to-cart-btn");
    if (!btn) return;
    var ready = areAllGroupsSelected();
    btn.disabled = !ready;
    btn.classList.toggle("opacity-50", !ready);
    btn.classList.toggle("cursor-not-allowed", !ready);
  }

  function getSelectedImages() {
    var allImages = [];
    document.querySelectorAll("[data-attribute-name]").forEach(function(group) {
      var selected = group.querySelector('[data-selected="true"]');
      if (selected) {
        try {
          var imgs = JSON.parse(selected.getAttribute("data-images") || "[]");
          allImages = allImages.concat(imgs);
        } catch(e) {}
      }
    });
    return allImages;
  }

  function getSelectedOptions() {
    var options = {};
    document.querySelectorAll("[data-attribute-name]").forEach(function(group) {
      var name = group.getAttribute("data-key");
      var selected = group.querySelector('[data-selected="true"]');
      if (selected) options[name] = selected.getAttribute("data-key");
    });
    return options;
  }

  function getSelectedModifiers() {
    var modifiers = [];
    document.querySelectorAll("[data-attribute-name]").forEach(function(group) {
      var selected = group.querySelector('[data-selected="true"]');
      if (selected) modifiers.push(parseFloat(selected.getAttribute("data-modifier") || "0"));
    });
    return modifiers;
  }

  function getSelectedOptionDiscounts() {
    var discounts = [];
    document.querySelectorAll("[data-attribute-name]").forEach(function(group) {
      var selected = group.querySelector('[data-selected="true"]');
      if (selected) {
        discounts.push({
          active: selected.getAttribute("data-discount-active") === "true",
          type: selected.getAttribute("data-discount-type"),
          value: parseFloat(selected.getAttribute("data-discount-value") || "0")
        });
      }
    });
    return discounts;
  }

  function calculatePrice(basePrice) {
    var modifiers = getSelectedModifiers();
    var optionDiscounts = getSelectedOptionDiscounts();
    var total = basePrice;
    modifiers.forEach(function(m) { total += m; });

    var bestDiscount = null;
    optionDiscounts.forEach(function(d) {
      if (d.active && (!bestDiscount || d.value > bestDiscount.value)) bestDiscount = d;
    });

    var productDiscount = JSON.parse(document.getElementById("product-discount-data")?.textContent || "{}");
    if (!bestDiscount && productDiscount.active) bestDiscount = productDiscount;

    if (!bestDiscount) return { price: total, original: total, hasDiscount: false, label: "" };

    var discounted;
    if (bestDiscount.type === "percentage") {
      discounted = Math.round(total * (1 - bestDiscount.value / 100));
    } else {
      discounted = Math.max(0, total - bestDiscount.value);
    }

    var label = bestDiscount.type === "percentage"
      ? uiText.percentOff.replace("{v}", bestDiscount.value)
      : uiText.amountOff.replace("{v}", bestDiscount.value);

    return { price: discounted, original: total, hasDiscount: true, label: label };
  }

  function renderPrice() {
    var btn = document.getElementById("add-to-cart-btn");
    var basePrice = parseFloat(btn?.getAttribute("data-base-price") || "0");
    var result = calculatePrice(basePrice);
    var display = document.getElementById("price-display");
    var html = "NPR " + result.price.toLocaleString();
    if (result.hasDiscount) {
      html += ' <span class="line-through text-text-3 font-normal text-base ml-1">NPR ' + result.original.toLocaleString() + "</span>";
      html += ' <span class="inline-flex items-center bg-sale text-white text-[0.62rem] font-bold px-1.5 py-0.5 rounded uppercase ml-1">' + result.label + "</span>";
    }
    display.innerHTML = html;
  }

  function updateURLParams() {
    var params = new URLSearchParams(window.location.search);
    document.querySelectorAll("[data-attribute-name]").forEach(function(group) {
      var name = group.getAttribute("data-key");
      var selected = group.querySelector('[data-selected="true"]');
      if (selected && name) {
        params.set(name, selected.getAttribute("data-key") || "");
      }
    });
    var newUrl = window.location.pathname + (params.toString() ? "?" + params.toString() : "");
    history.replaceState(null, "", newUrl);
  }

  function readURLParams() {
    var params = new URLSearchParams(window.location.search);
    document.querySelectorAll("[data-attribute-name]").forEach(function(group) {
      var key = group.getAttribute("data-key");
      var paramValue = params.get(key);
      if (paramValue) {
        var options = group.querySelectorAll(".attr-option");
        for (var i = 0; i < options.length; i++) {
          if (options[i].getAttribute("data-key") === paramValue) {
            selectOption(options[i]);
            break;
          }
        }
      }
    });
  }

  function updateCheckoutVisibility() {
    var btn = document.getElementById("add-to-cart-btn");
    var productSlug = btn?.getAttribute("data-product-slug") || "";
    var cart = getCart();
    var inCart = cart.some(function(c) { return c.slug === productSlug; });
    var checkoutBtn = document.getElementById("go-checkout-btn");
    if (checkoutBtn) {
      checkoutBtn.classList.toggle("hidden", !inCart);
      checkoutBtn.classList.toggle("flex", inCart);
    }
  }

  window.__attrCtx = window.__attrCtx || { id: 0, abort: null };
  var _attrId = ++window.__attrCtx.id;

  function init() {
    if (window.__attrCtx.abort) window.__attrCtx.abort.abort();
    window.__attrCtx.abort = new AbortController();
    var signal = window.__attrCtx.abort.signal;

    document.querySelectorAll(".attr-option").forEach(function(btn) {
      btn.addEventListener("click", function() {
        selectOption(this);
        renderPrice();
        updateAddToCartState();
        updateURLParams();
      }, { signal: signal });
    });

    var qtyInput = document.getElementById("qty-input");
    var qtyMinus = document.getElementById("qty-minus");
    var qtyPlus = document.getElementById("qty-plus");

    if (qtyMinus) qtyMinus.addEventListener("click", function() {
      var val = parseInt(qtyInput.value) || 1;
      if (val > 1) qtyInput.value = String(val - 1);
    }, { signal: signal });

    if (qtyPlus) qtyPlus.addEventListener("click", function() {
      var val = parseInt(qtyInput.value) || 1;
      if (val < 99) qtyInput.value = String(val + 1);
    }, { signal: signal });

    if (qtyInput) qtyInput.addEventListener("change", function() {
      var val = parseInt(this.value) || 1;
      this.value = String(Math.max(1, Math.min(99, val)));
    }, { signal: signal });

    document.getElementById("add-to-cart-btn").addEventListener("click", function() {
      if (this.disabled) return;

      var btn = this;
      var qty = parseInt(document.getElementById("qty-input")?.value) || 1;
      var basePrice = parseFloat(btn.getAttribute("data-base-price") || "0");
      var productSlug = btn.getAttribute("data-product-slug") || "";
      var productName = btn.getAttribute("data-product-name") || "";
      var productNameAll = JSON.parse(btn.getAttribute("data-product-name-all") || "{}");
      var productImage = btn.getAttribute("data-product-image") || "";

      var result = calculatePrice(basePrice);
      var cart = getCart();
      var options = getSelectedOptions();
      var modifiers = getSelectedModifiers();

      var existing = cart.findIndex(function(c) {
        return c.slug === productSlug && JSON.stringify(c.selectedOptions) === JSON.stringify(options);
      });

      if (existing >= 0) {
        cart[existing].qty += qty;
      } else {
        cart.push({
          slug: productSlug,
          name: productName,
          nameAll: productNameAll,
          image: productImage,
          images: getSelectedImages(),
          selectedOptions: options,
          selectedModifiers: modifiers,
          unitPrice: result.price,
          originalUnitPrice: result.original,
          hasDiscount: result.hasDiscount,
          qty: qty
        });
      }

      saveCart(cart);
      btn.textContent = uiText.added;
      btn.classList.add("bg-success");
      btn.classList.remove("bg-accent");
      setTimeout(function() {
        btn.textContent = uiText.addToCart;
        btn.classList.remove("bg-success");
        btn.classList.add("bg-accent");
      }, 1500);

      if (qtyInput) qtyInput.value = "1";
      updateCheckoutVisibility();
    }, { signal: signal });
  }

  document.addEventListener("astro:page-load", function() {
    if (window.__attrCtx.id !== _attrId) return;
    if (!document.getElementById("add-to-cart-btn")) return;
    init();
    readURLParams();
    renderPrice();
    updateAddToCartState();
    updateCheckoutVisibility();
  });
</script>
