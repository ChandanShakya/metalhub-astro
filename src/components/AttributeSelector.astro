---
import type { Locale } from "../lib/i18n";
import { getTranslations } from "../lib/i18n";

interface LocalizedString {
    en: string;
    ne: string;
    newa: string;
}
interface AttributeOption {
    label: LocalizedString;
}
interface AttributeGroup {
    name: LocalizedString;
    options: AttributeOption[];
}
interface VariantDiscount {
    active: boolean;
    type: "percentage" | "flat";
    value: number;
    saleType?: string;
    eventName?: string;
    startDate?: string;
    endDate?: string;
}
interface VariantAttrValue {
    group: string;
    option: string;
}
interface Variant {
    key: string;
    attributeValues: VariantAttrValue[];
    priceModifier: number;
    discount: VariantDiscount;
    images?: string[];
    inStock: boolean;
    stock: number;
}
interface Props {
    attributeGroups: AttributeGroup[];
    variants: Variant[];
    locale: Locale;
    basePrice: number;
    productSlug: string;
    productName: string;
    productNameAll: LocalizedString;
    productImage?: string;
}
const { attributeGroups, variants, locale, basePrice, productSlug, productName, productNameAll, productImage } =
    Astro.props;
const t = await getTranslations(locale);
const checkoutPath = locale === "en" ? "/checkout/" : `/${locale}/checkout/`;
const totalStock = variants.reduce((s, v) => s + (v.stock ?? 0), 0);

function localize(obj: LocalizedString): string {
    return obj[locale] || obj.en;
}

const allAttributeLabels: Record<string, Record<string, string>> = {};
for (const loc of ["en", "ne", "newa"] as const) {
    allAttributeLabels[loc] = {};
    for (const group of attributeGroups) {
        allAttributeLabels[loc][group.name.en] = group.name[loc] || group.name.en;
        for (const opt of group.options) {
            allAttributeLabels[loc][opt.label.en] = opt.label[loc] || opt.label.en;
        }
    }
}
---

<div id="product-attributes" data-variants={JSON.stringify(variants)} data-base-price={basePrice}>
  {attributeGroups.map((group) => (
    <fieldset class="mb-4 border-none p-0 m-0">
      <legend class="block font-semibold text-sm mb-2 text-text-1 p-0">{localize(group.name)}</legend>
      <div class="flex gap-2 flex-wrap" data-attribute-name={localize(group.name)} data-key={group.name.en}>
        {group.options.map((opt) => (
          <button
            class="attr-option px-3.5 py-2 bg-surface-2 border-2 border-border rounded-lg cursor-pointer text-sm font-medium transition-[colors,transform] text-text-1 hover:border-accent-light"
            data-label={localize(opt.label)}
            data-key={opt.label.en}
            data-selected="false"
          >
            {localize(opt.label)}
          </button>
        ))}
      </div>
    </fieldset>
  ))}
</div>

<div id="variant-unavailable" class="hidden text-sale text-sm font-medium my-2">Combination not available</div>
<div id="price-display" class="text-2xl font-extrabold my-4 text-text-1"></div>
<div id="sale-event-display" class="mb-2"></div>

<div class="flex items-center gap-3 mb-2">
  <label for="qty-input" class="text-sm font-medium text-text-2">{t("products.qty")}</label>
  <div class="flex items-center border-2 border-border rounded-lg overflow-hidden">
    <button id="qty-minus" aria-label="Decrease quantity" class="w-9 h-9 flex items-center justify-center bg-surface-2 cursor-pointer transition-colors hover:bg-surface-3 text-text-1 font-bold border-none">-</button>
    <input id="qty-input" type="number" min="1" max="99" value="1" class="w-12 h-9 text-center border-none bg-surface-2 text-text-1 font-semibold text-base [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none" />
    <button id="qty-plus" aria-label="Increase quantity" class="w-9 h-9 flex items-center justify-center bg-surface-2 cursor-pointer transition-colors hover:bg-surface-3 text-text-1 font-bold border-none">+</button>
  </div>
  <span id="stock-display" data-total-stock={totalStock} class="inline-flex items-center text-[0.62rem] font-bold px-1.5 py-0.5 rounded uppercase tracking-wide"></span>
</div>

<div class="flex flex-col gap-2 mt-2">
  <div class="flex items-center gap-3">
    <button
      id="add-to-cart-btn"
      class="flex-1 bg-accent text-white border-none rounded-xl py-3 px-6 text-base font-semibold cursor-pointer transition-[colors,transform] opacity-50 cursor-not-allowed"
      data-base-price={basePrice}
      data-product-slug={productSlug}
      data-product-name={productName}
      data-product-name-all={JSON.stringify(productNameAll)}
      data-product-image={productImage}
      data-attribute-labels={JSON.stringify(allAttributeLabels)}
      data-ui-text={JSON.stringify({ added: t("products.added"), addToCart: t("products.addToCart"), percentOff: t("products.percentOff"), amountOff: t("products.amountOff") })}
      disabled
    >
      {t("products.addToCart")}
    </button>
  </div>
  <a id="go-checkout-btn" href={checkoutPath} class="hidden items-center justify-center bg-success text-white border-none rounded-xl py-3 px-6 text-base font-semibold cursor-pointer no-underline transition-[colors,transform] hover:bg-green-800 hover:-translate-y-px">
    {t("products.goToCheckout")}
  </a>
</div>

<script is:inline define:vars={{ checkoutPath }}>
  var CART_KEY = "metalhub-cart";
  var uiText = JSON.parse(document.getElementById("add-to-cart-btn")?.getAttribute("data-ui-text") || "{}");

  function getCart() {
    try { return JSON.parse(localStorage.getItem(CART_KEY) || "[]"); } catch { return []; }
  }
  function saveCart(items) {
    localStorage.setItem(CART_KEY, JSON.stringify(items));
    window.dispatchEvent(new Event("cart-updated"));
  }

  function getVariants() {
    var el = document.getElementById("product-attributes");
    try { return JSON.parse(el?.getAttribute("data-variants") || "[]"); } catch { return []; }
  }

  function getBasePrice() {
    var el = document.getElementById("product-attributes");
    return parseFloat(el?.getAttribute("data-base-price") || "0");
  }

  function selectOption(btn) {
    var group = btn.closest("[data-attribute-name]");
    if (!group) return;
    var isSelected = btn.getAttribute("data-selected") === "true";
    group.querySelectorAll(".attr-option").forEach(function(b) {
      b.setAttribute("data-selected", "false");
      b.classList.remove("border-accent", "bg-accent-surface", "text-accent-dark", "font-semibold");
      b.classList.add("border-border", "bg-surface-2", "text-text-1");
    });
    if (!isSelected) {
      btn.setAttribute("data-selected", "true");
      btn.classList.remove("border-border", "bg-surface-2", "text-text-1");
      btn.classList.add("border-accent", "bg-accent-surface", "text-accent-dark", "font-semibold");
    }

    // Dispatch image changed if matching variant has images
    var matched = findMatchingVariant();
    if (matched && matched.images && matched.images.length > 0) {
      window.dispatchEvent(new CustomEvent("attribute-image-changed", { detail: { images: matched.images } }));
    }
  }

  function getSelectedOptions() {
    var options = {};
    document.querySelectorAll("[data-attribute-name]").forEach(function(group) {
      var name = group.getAttribute("data-key");
      var selected = group.querySelector('[data-selected="true"]');
      if (selected) options[name] = selected.getAttribute("data-key");
    });
    return options;
  }

  function findMatchingVariant() {
    var selected = getSelectedOptions();
    var variants = getVariants();
    var selectedKeys = Object.keys(selected);
    if (selectedKeys.length === 0) return null;
    return variants.find(function(v) {
      return v.attributeValues.every(function(av) {
        return selected[av.group] === av.option;
      });
    }) || null;
  }

  function getAvailableOptions(groupName) {
    var selected = getSelectedOptions();
    var variants = getVariants();
    var available = new Set();
    variants.forEach(function(v) {
      var matches = true;
      v.attributeValues.forEach(function(av) {
        if (av.group !== groupName && selected[av.group] && selected[av.group] !== av.option) {
          matches = false;
        }
      });
      if (matches) {
        v.attributeValues.forEach(function(av) {
          if (av.group === groupName) available.add(av.option);
        });
      }
    });
    return available;
  }

  function filterOptions() {
    document.querySelectorAll("[data-attribute-name]").forEach(function(group) {
      var key = group.getAttribute("data-key");
      var available = getAvailableOptions(key);
      group.querySelectorAll(".attr-option").forEach(function(btn) {
        var optKey = btn.getAttribute("data-key");
        var isAvailable = available.has(optKey);
        btn.disabled = !isAvailable;
        btn.classList.toggle("opacity-40", !isAvailable);
        btn.classList.toggle("cursor-not-allowed", !isAvailable);
        btn.classList.toggle("cursor-pointer", isAvailable);
      });
    });
  }

  function areAllGroupsSelected() {
    var groups = document.querySelectorAll("[data-attribute-name]");
    for (var i = 0; i < groups.length; i++) {
      if (!groups[i].querySelector('[data-selected="true"]')) return false;
    }
    return groups.length > 0;
  }

  function updateAddToCartState() {
    var btn = document.getElementById("add-to-cart-btn");
    if (!btn) return;
    var ready = areAllGroupsSelected();
    var matched = ready ? findMatchingVariant() : null;
    var isAvailable = matched && matched.inStock;
    btn.disabled = !(ready && isAvailable);
    btn.classList.toggle("opacity-50", !(ready && isAvailable));
    btn.classList.toggle("cursor-not-allowed", !(ready && isAvailable));

    var unavailable = document.getElementById("variant-unavailable");
    if (unavailable) {
      unavailable.classList.toggle("hidden", !ready || !!matched);
    }
  }

  function getSelectedOptionLabels() {
    var raw = document.getElementById("add-to-cart-btn")?.getAttribute("data-attribute-labels") || "{}";
    try { return JSON.parse(raw); } catch { return {}; }
  }

  function isSaleActive(discount) {
    if (!discount || !discount.active) return false;
    if (!discount.startDate || !discount.endDate) return discount.active;
    var now = new Date();
    var start = new Date(discount.startDate);
    var end = new Date(discount.endDate);
    end.setHours(23, 59, 59, 999);
    return now >= start && now <= end;
  }

  function calculateVariantPrice(variant) {
    var base = getBasePrice();
    var total = base + (variant.priceModifier || 0);
    var productData = {};
    try {
      productData = JSON.parse(document.getElementById("product-data")?.getAttribute("data-product") || "{}");
    } catch(e) {}

    if (variant.discount && isSaleActive(variant.discount)) {
      var disc = variant.discount;
      var discounted;
      if (disc.type === "percentage") {
        discounted = Math.round(total * (1 - disc.value / 100));
      } else {
        discounted = Math.max(0, total - disc.value);
      }
      var label = disc.type === "percentage"
        ? uiText.percentOff.replace("{v}", disc.value)
        : uiText.amountOff.replace("{v}", disc.value);
      var saleType = disc.saleType || (productData.discount && productData.discount.saleType) || "";
      var eventName = disc.eventName || (productData.discount && productData.discount.eventName) || "";
      return { price: discounted, original: total, hasDiscount: true, label: label, saleType: saleType, eventName: eventName };
    }

    if (productData.discount && isSaleActive(productData.discount)) {
      var pdisc = productData.discount;
      var pDiscounted;
      if (pdisc.type === "percentage") {
        pDiscounted = Math.round(total * (1 - pdisc.value / 100));
      } else {
        pDiscounted = Math.max(0, total - pdisc.value);
      }
      var pLabel = pdisc.type === "percentage"
        ? uiText.percentOff.replace("{v}", pdisc.value)
        : uiText.amountOff.replace("{v}", pdisc.value);
      return { price: pDiscounted, original: total, hasDiscount: true, label: pLabel, saleType: pdisc.saleType || "", eventName: pdisc.eventName || "" };
    }

    return { price: total, original: total, hasDiscount: false, label: "", saleType: "", eventName: "" };
  }

  function renderStock() {
    var display = document.getElementById("stock-display");
    if (!display) return;
    var matched = findMatchingVariant();
    if (matched) {
      var stock = matched.stock || 0;
      display.textContent = stock > 0 ? "Stock: " + stock : "Out of Stock";
      display.className = "inline-flex items-center text-[0.62rem] font-bold px-1.5 py-0.5 rounded uppercase tracking-wide "
        + (stock > 0 ? "bg-success text-white" : "bg-sale text-white");
    } else {
      var selected = getSelectedOptions();
      var keys = Object.keys(selected);
      if (keys.length > 0) {
        display.textContent = "";
        display.className = "";
      } else {
        var total = parseInt(display.getAttribute("data-total-stock") || "0");
        display.textContent = total > 0 ? "Stock: " + total : "";
        display.className = total > 0
          ? "inline-flex items-center text-[0.62rem] font-bold px-1.5 py-0.5 rounded uppercase tracking-wide bg-success text-white"
          : "";
      }
    }
  }

  function localizeSpec(obj) {
    var locale = document.getElementById("specs-display")?.getAttribute("data-locale") || "en";
    return obj && (obj[locale] || obj.en);
  }

  function renderSpecs() {
    var display = document.getElementById("specs-display");
    if (!display) return;
    var matched = findMatchingVariant();
    var specs;
    if (matched && matched.specifications && matched.specifications.length > 0) {
      specs = matched.specifications;
    } else {
      try {
        var productData = JSON.parse(document.getElementById("product-data")?.getAttribute("data-product") || "{}");
        specs = productData.specifications || [];
      } catch { specs = []; }
    }

    if (specs.length === 0) {
      display.innerHTML = "";
      return;
    }

    var html = '<section><h2 class="text-lg font-bold mb-3">Specifications</h2><dl class="grid grid-cols-1 md:grid-cols-2 gap-2">';
    for (var i = 0; i < specs.length; i++) {
      var label = localizeSpec(specs[i].label);
      var value = localizeSpec(specs[i].value);
      html += '<div class="flex border-b border-border py-2"><dt class="font-medium text-text-2 w-1/3">' + label + '</dt><dd class="text-text-1 w-2/3">' + value + '</dd></div>';
    }
    html += '</dl></section>';
    display.innerHTML = html;
  }

  function renderPrice() {
    var display = document.getElementById("price-display");
    var eventDisplay = document.getElementById("sale-event-display");
    var matched = findMatchingVariant();
    if (!matched) {
      var selected = getSelectedOptions();
      var keys = Object.keys(selected);
      if (keys.length > 0) {
        display.innerHTML = '<span class="text-text-3 text-base font-normal">Combination not available</span>';
        if (eventDisplay) eventDisplay.innerHTML = "";
      } else {
        display.innerHTML = "NPR " + getBasePrice().toLocaleString();
        if (eventDisplay) eventDisplay.innerHTML = "";
      }
      return;
    }
    var result = calculateVariantPrice(matched);
    var html = "NPR " + result.price.toLocaleString();
    if (result.hasDiscount) {
      html += ' <span class="line-through text-text-3 font-normal text-base ml-1">NPR ' + result.original.toLocaleString() + "</span>";
      html += ' <span class="inline-flex items-center bg-sale text-white text-[0.62rem] font-bold px-1.5 py-0.5 rounded uppercase ml-1">' + result.label + "</span>";
    }
    display.innerHTML = html;
    if (eventDisplay) {
      if (result.hasDiscount && (result.saleType || result.eventName)) {
        var displayText = result.saleType || result.eventName;
        eventDisplay.innerHTML = '<span class="inline-flex items-center bg-sale/10 text-sale text-xs font-semibold px-2 py-1 rounded-lg">🔥 ' + displayText + '</span>';
      } else {
        eventDisplay.innerHTML = "";
      }
    }
  }

  function updateURLParams() {
    var params = new URLSearchParams(window.location.search);
    document.querySelectorAll("[data-attribute-name]").forEach(function(group) {
      var name = group.getAttribute("data-key");
      var selected = group.querySelector('[data-selected="true"]');
      if (selected && name) {
        params.set(name, selected.getAttribute("data-key") || "");
      }
    });
    var newUrl = window.location.pathname + (params.toString() ? "?" + params.toString() : "");
    history.replaceState(null, "", newUrl);
  }

  function readURLParams() {
    var params = new URLSearchParams(window.location.search);
    document.querySelectorAll("[data-attribute-name]").forEach(function(group) {
      var key = group.getAttribute("data-key");
      var paramValue = params.get(key);
      if (paramValue) {
        var options = group.querySelectorAll(".attr-option");
        for (var i = 0; i < options.length; i++) {
          if (options[i].getAttribute("data-key") === paramValue && !options[i].disabled) {
            selectOption(options[i]);
            break;
          }
        }
      }
    });
  }

  function updateCheckoutVisibility() {
    var btn = document.getElementById("add-to-cart-btn");
    var productSlug = btn?.getAttribute("data-product-slug") || "";
    var cart = getCart();
    var inCart = cart.some(function(c) { return c.slug === productSlug; });
    var checkoutBtn = document.getElementById("go-checkout-btn");
    if (checkoutBtn) {
      checkoutBtn.classList.toggle("hidden", !inCart);
      checkoutBtn.classList.toggle("flex", inCart);
    }
  }

  function getQtyMax() {
    var input = document.getElementById("qty-input");
    return parseInt(input?.getAttribute("max") || "99");
  }

  function updateQtyMax() {
    var input = document.getElementById("qty-input");
    if (!input) return;
    var matched = findMatchingVariant();
    var max = matched ? (matched.stock || 1) : 99;
    input.setAttribute("max", String(max));
    var val = parseInt(input.value) || 1;
    if (val > max) input.value = String(max);
  }

  window.__attrCtx = window.__attrCtx || { id: 0, abort: null };
  var _attrId = ++window.__attrCtx.id;

  function init() {
    if (window.__attrCtx.abort) window.__attrCtx.abort.abort();
    window.__attrCtx.abort = new AbortController();
    var signal = window.__attrCtx.abort.signal;

    document.querySelectorAll(".attr-option").forEach(function(btn) {
      btn.addEventListener("click", function() {
        selectOption(this);
        filterOptions();
        renderPrice();
        renderStock();
        renderSpecs();
        updateQtyMax();
        updateAddToCartState();
        updateURLParams();
      }, { signal: signal });
    });

    var qtyInput = document.getElementById("qty-input");
    var qtyMinus = document.getElementById("qty-minus");
    var qtyPlus = document.getElementById("qty-plus");

    if (qtyMinus) qtyMinus.addEventListener("click", function() {
      var val = parseInt(qtyInput.value) || 1;
      if (val > 1) qtyInput.value = String(val - 1);
    }, { signal: signal });

    if (qtyPlus) qtyPlus.addEventListener("click", function() {
      var val = parseInt(qtyInput.value) || 1;
      var max = getQtyMax();
      if (val < max) qtyInput.value = String(val + 1);
    }, { signal: signal });

    if (qtyInput) qtyInput.addEventListener("change", function() {
      var val = parseInt(this.value) || 1;
      var max = getQtyMax();
      this.value = String(Math.max(1, Math.min(max, val)));
    }, { signal: signal });

    document.getElementById("add-to-cart-btn").addEventListener("click", function() {
      if (this.disabled) return;

      var btn = this;
      var qty = parseInt(document.getElementById("qty-input")?.value) || 1;
      var basePrice = parseFloat(btn.getAttribute("data-base-price") || "0");
      var productSlug = btn.getAttribute("data-product-slug") || "";
      var productName = btn.getAttribute("data-product-name") || "";
      var productNameAll = JSON.parse(btn.getAttribute("data-product-name-all") || "{}");
      var productImage = btn.getAttribute("data-product-image") || "";

      var matched = findMatchingVariant();
      if (!matched) return;

      var result = calculateVariantPrice(matched);
      var cart = getCart();
      var options = getSelectedOptions();
      var allLabels = getAllOptionLabels();

      var cartItem = {
        slug: productSlug,
        name: productName,
        nameAll: productNameAll,
        image: productImage,
        images: matched.images || [],
        selectedOptions: options,
        selectedOptionsLabelsAll: allLabels,
        variantKey: matched.key,
        unitPrice: result.price,
        originalUnitPrice: result.original,
        hasDiscount: result.hasDiscount,
        qty: qty
      };

      var existing = cart.findIndex(function(c) {
        return c.slug === productSlug && c.variantKey === matched.key;
      });

      if (existing >= 0) {
        cart[existing].qty += qty;
      } else {
        cart.push(cartItem);
      }

      saveCart(cart);
      btn.textContent = uiText.added;
      btn.classList.add("bg-success");
      btn.classList.remove("bg-accent");
      setTimeout(function() {
        btn.textContent = uiText.addToCart;
        btn.classList.remove("bg-success");
        btn.classList.add("bg-accent");
      }, 1500);

      if (qtyInput) qtyInput.value = "1";
      updateCheckoutVisibility();
    }, { signal: signal });
  }

  function getAllOptionLabels() {
    var raw = document.getElementById("add-to-cart-btn")?.getAttribute("data-attribute-labels") || "{}";
    try { return JSON.parse(raw); } catch { return {}; }
  }

  document.addEventListener("astro:page-load", function() {
    if (window.__attrCtx.id !== _attrId) return;
    if (!document.getElementById("add-to-cart-btn")) return;
    init();
    readURLParams();
    filterOptions();
    renderPrice();
    renderStock();
    renderSpecs();
    updateQtyMax();
    updateAddToCartState();
    updateCheckoutVisibility();
  });
</script>
